@page "/progressivebotsystem/pmc"
@using _progressiveBotSystem.Web.Components
@layout MainLayout

@inject ISnackbar Snackbar

<MudMainContent>
    <MudContainer Class="mb-20">
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="PMC Specific Configuration" Expanded="true">
                <MudGrid>

                    <MudSwitchTTWarning
                        Label="PMC Bot Generation"
                        TooltipText="Grants APBS control over PMC Bots. You will have vanilla versions of these bots if disabled."
                        WarningTooltip1="All settings on this page, and any other setting that may impact these bots are controlled by this toggle."
                        WarningTooltip2="EXCEPTION: Normalize Health is always applied if enabled but not excluded."
                        @bind-Value="PmcEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("_pmcEnabled"))"
                        IsNonDefault="@(!PmcEnabled)"
                        OnUndo="UndoPmcBots"
                        OnDefault="DefaultPmcBots" />

                </MudGrid>
            </MudExpansionPanel>
            @if (PmcEnabled)
            {
                <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Style="padding-bottom:25px" Text="PMC Specific Options" Expanded="true">
                    <MudGrid>

                        <MudSwitchTT
                            Label="Loot"
                            TooltipText="Allows PMC Bots to spawn with additional loot."
                            @bind-Value="PmcLootEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcLootEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcLootBlacklist"))"
                            IsNonDefault="@(PmcLootEnabled ||
                                            PmcLootBlacklist.Count != 0)"
                            OnUndo="UndoLoot"
                            OnDefault="DefaultLoot" />

                        <LootBlacklistValues
                            Blacklist="PmcLootBlacklist"
                            OriginalBlacklist="ModConfig.OriginalConfig.PmcBots.LootConfig.Blacklist"
                            ChangeKey="PmcLootBlacklist" />

                        <MudDivider DividerType="DividerType.FullWidth" Class="my-3" />

                        <MudSwitchTT
                            Label="Prestiging"
                            TooltipText="Allow PMCs to prestige with the player."
                            @bind-Value="PmcPrestigeEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcPrestigeEnabled"))"
                            IsNonDefault="@(!PmcPrestigeEnabled)"
                            OnUndo="UndoPrestiging"
                            OnDefault="DefaultPrestiging" />

                        <MudSwitchTT
                            Label="Bots Can Be Any Level if Prestiged"
                            TooltipText="Allow bots to be any level if the player has prestiged. Required Prestiging enabled."
                            @bind-Value="PmcPrestigeAnyLevel"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcPrestigeAnyLevel"))"
                            IsNonDefault="@(!PmcPrestigeAnyLevel)"
                            OnUndo="UndoPrestigeAnyLevel"
                            OnDefault="DefaultPrestigeAnyLevel" />

                        <MudSwitchTT
                            Label="Roll Ammunition Selection Again"
                            TooltipText="Allows PMCs to reroll their selected round from their weapons caliber, max one time per each magazine."
                            @bind-Value="PmcWeaponAmmunitionRollEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcWeaponAmmunitionRollEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcWeaponAmmunitionRollChance"))"
                            IsNonDefault="@(PmcWeaponAmmunitionRollEnabled ||
                                            PmcWeaponAmmunitionRollChance != 50)"
                            OnUndo="UndoRollAmmunitionEnabled"
                            OnDefault="DefaultRollAmmunitionEnabled" />

                        <MudSliderChildTT
                            Label="Roll Again Chance"
                            TooltipText="This is the chance that PMCs will roll for a different round from the same caliber, max one time per each magazine."
                            @bind-Value="PmcWeaponAmmunitionRollChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcWeaponAmmunitionRollEnabled)" />

                        <MudSwitchTT
                            Label="Toploading"
                            TooltipText="Allows PMCs to top load their extra magazines."
                            @bind-Value="PmcWeaponToploadEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcWeaponToploadEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcWeaponToploadEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcWeaponToploadPercent"))"
                            IsNonDefault="@(!PmcWeaponToploadEnabled ||
                                            PmcWeaponToploadChance != 30 ||
                                            PmcWeaponToploadPercent != 30)"
                            OnUndo="UndoToploadEnabled"
                            OnDefault="DefaultToploadEnabled" />

                        <MudSliderChildTT
                            Label="Topload Chance"
                            TooltipText="This is the chance that PMCs will topload their extra magazines."
                            @bind-Value="PmcWeaponToploadChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcWeaponToploadEnabled)" />

                        <MudSliderChildTT
                            Label="Topload Percent"
                            TooltipText="This is the percentage of their extra magazine that PMCs will topload."
                            @bind-Value="PmcWeaponToploadPercent"
                            Min="10"
                            Max="50"
                            Disabled="@(!PmcWeaponToploadEnabled)" />

                        <MudSwitchTT
                            Label="Resource Randomization"
                            TooltipText="Allows random resource consumption on Food/Drink/Medical Items."
                            @bind-Value="PmcResourceRandomizationEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcResourceRandomizationEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcMedRateMaxChance") ||
                                                MainLayout.pendingChanges.Contains("PmcMedRateUsagePercent") ||
                                                MainLayout.pendingChanges.Contains("PmcFoodRateMaxChance") ||
                                                MainLayout.pendingChanges.Contains("PmcFoodRateUsagePercent"))"
                            IsNonDefault="@(!PmcResourceRandomizationEnabled ||
                                            PmcMedRateMaxChance != 10 ||
                                            PmcMedRateUsagePercent != 33 ||
                                            PmcFoodRateMaxChance != 10 ||
                                            PmcFoodRateUsagePercent != 33)"
                            OnUndo="UndoResourceRandomization"
                            OnDefault="DefaultResourceRandomization" />

                        <MedicalFoodValues
                            @bind-MedMaxChance="PmcMedRateMaxChance"
                            @bind-MedUsagePercent="PmcMedRateUsagePercent"
                            @bind-FoodMaxChance="PmcFoodRateMaxChance"
                            @bind-FoodUsagePercent="PmcFoodRateUsagePercent"
                            Disabled="@(!PmcResourceRandomizationEnabled)" />

                        <MudSwitchTT
                            Label="Weapon Durability Changes"
                            TooltipText="Allows configurable weapon durability."
                            @bind-Value="PmcWeaponDurabilityEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcWeaponDurabilityEnabled") ||
                                               MainLayout.pendingChanges.Contains("PmcWeaponDurabilityMin") ||
                                               MainLayout.pendingChanges.Contains("PmcWeaponDurabilityMax") ||
                                               MainLayout.pendingChanges.Contains("PmcWeaponDurabilityMinDelta") ||
                                               MainLayout.pendingChanges.Contains("PmcWeaponDurabilityMaxDelta") ||
                                               MainLayout.pendingChanges.Contains("PmcWeaponDurabilityEnhancementChance"))"
                            IsNonDefault="@(!PmcWeaponDurabilityEnabled ||
                                          PmcWeaponDurabilityMin != 95 ||
                                          PmcWeaponDurabilityMax != 100 ||
                                          PmcWeaponDurabilityMinDelta != 0 ||
                                          PmcWeaponDurabilityMaxDelta != 5 ||
                                          PmcWeaponDurabilityEnhancementChance != 10)"
                            OnUndo="UndoWeaponDurability"
                            OnDefault="DefaultWeaponDurability" />

                        <DurabilityValues
                            Label="Weapon"
                            @bind-Min="PmcWeaponDurabilityMin"
                            @bind-Max="PmcWeaponDurabilityMax"
                            @bind-MinDelta="PmcWeaponDurabilityMinDelta"
                            @bind-MaxDelta="PmcWeaponDurabilityMaxDelta"
                            MinLimitPercent="PmcWeaponDurabilityMinLimitPercent"
                            MaxLimitPercent="PmcWeaponDurabilityMaxLimitPercent"
                            Disabled="@(!PmcWeaponDurabilityEnabled)" />

                        <MudSliderChildTT
                            Label="Enhancement Chance"
                            TooltipText="This is the chance that bot weapons have an enhancement applied to them."
                            @bind-Value="PmcWeaponDurabilityEnhancementChance"
                            Min="0"
                            Max="100"
                            Disabled="@(!PmcWeaponDurabilityEnabled)" />

                        <MudSwitchTT
                            Label="Armour Durability Changes"
                            TooltipText="Allows configurable armour durability."
                            @bind-Value="PmcArmourDurabilityEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcArmourDurabilityEnabled") ||
                                               MainLayout.pendingChanges.Contains("PmcArmourDurabilityMin") ||
                                               MainLayout.pendingChanges.Contains("PmcArmourDurabilityMax") ||
                                               MainLayout.pendingChanges.Contains("PmcArmourDurabilityMinDelta") ||
                                               MainLayout.pendingChanges.Contains("PmcArmourDurabilityMaxDelta"))"
                            IsNonDefault="@(!PmcArmourDurabilityEnabled ||
                                          PmcArmourDurabilityMin != 95 ||
                                          PmcArmourDurabilityMax != 100 ||
                                          PmcArmourDurabilityMinDelta != 0 ||
                                          PmcArmourDurabilityMaxDelta != 5)"
                            OnUndo="UndoArmourDurability"
                            OnDefault="DefaultArmourDurability" />

                        <DurabilityValues
                            Label="Armour"
                            @bind-Min="PmcArmourDurabilityMin"
                            @bind-Max="PmcArmourDurabilityMax"
                            @bind-MinDelta="PmcArmourDurabilityMinDelta"
                            @bind-MaxDelta="PmcArmourDurabilityMaxDelta"
                            MinLimitPercent="PmcArmourDurabilityMinLimitPercent"
                            MaxLimitPercent="PmcArmourDurabilityMaxLimitPercent"
                            Disabled="@(!PmcArmourDurabilityEnabled)" />

                        <MudSwitchTT
                            Label="Seasonal PMC Appearance"
                            TooltipText="PMCs will wear clothing that more closely resembles the active season."
                            @bind-Value="PmcSeasonalAppearanceEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcSeasonalAppearanceEnabled"))"
                            IsNonDefault="@(!PmcSeasonalAppearanceEnabled)"
                            OnUndo="UndoPmcSeasonalAppearance"
                            OnDefault="DefaultPmcSeasonalAppearance" />

                        <MudSwitchTT
                            Label="Quest Loadouts"
                            TooltipText="PMCs have a chance to wear quest loadouts on appropriate maps at appropriate levels."
                            @bind-Value="PmcQuestLoadoutEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcQuestLoadoutEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcQuestLoadoutChance"))"
                            IsNonDefault="@(!PmcQuestLoadoutEnabled || 
                                            PmcQuestLoadoutChance != 5)"
                            OnUndo="UndoPmcQuestLoadouts"
                            OnDefault="DefaultPmcQuestLoadouts" />

                        <MudSliderChildTT
                            Label="Quest Chance"
                            TooltipText="Chance of them using quest loadouts."
                            @bind-Value="PmcQuestLoadoutChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcQuestLoadoutEnabled)" />

                        <MudSwitchTTWarning
                            Label="Poverty Check"
                            TooltipText=""
                            WarningTooltip1="PMCs have a chance to be poor compared to other PMCs at their level & tier, if they are not assigned a quest."
                            WarningTooltip2="Disabling this means they will always use gear that is available in their tier."
                            @bind-Value="PmcPovertyEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcPovertyEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcPovertyChance"))"
                            IsNonDefault="@(!PmcPovertyEnabled || 
                                            PmcPovertyChance != 5)"
                            OnUndo="UndoPmcPoverty"
                            OnDefault="DefaultPmcPoverty" />

                        <MudSliderChildTT
                            Label="Poverty Chance"
                            TooltipText="Chance of PMC being poor for their level, this is not rolled if they are assigned a quest."
                            @bind-Value="PmcPovertyChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcPovertyEnabled)" />

                        <MudSwitchTT
                            Label="Ammo Tier Sliding"
                            TooltipText="Allows PMCs to slide down to a lower ammo pool tier when they are generated."
                            @bind-Value="PmcAmmoTierSlideEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcAmmoTierSlideEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcAmmoTierSlideAmount") ||
                                                MainLayout.pendingChanges.Contains("PmcAmmoTierSlideChance"))"
                            IsNonDefault="@(PmcAmmoTierSlideEnabled ||
                                            PmcAmmoTierSlideAmount != 1 ||
                                            PmcAmmoTierSlideChance != 33)"
                            OnUndo="UndoPmcAmmoTierSliding"
                            OnDefault="DefaultPmcAmmoTierSliding" />

                        <MudSliderChildTT
                            Label="Slide Amount"
                            TooltipText="How many tiers they can slide downward."
                            @bind-Value="PmcAmmoTierSlideAmount"
                            Min="1"
                            Max="7"
                            Disabled="@(!PmcAmmoTierSlideEnabled)" />

                        <MudSliderChildTT
                            Label="Slide Chance"
                            TooltipText="Chance they slide down tiers."
                            @bind-Value="PmcAmmoTierSlideChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcAmmoTierSlideEnabled)" />

                        <MudSliderChildTT
                            Label="TUE/EOD Specific Dogtag Chance"
                            TooltipText="If the bot is Unheard or EOD, how often they should have that dogtag."
                            @bind-Value="PmcVersionDogtagChance"
                            Min="0"
                            Max="100" />

                        <MudSwitchTT
                            Label="Game Version Weighting"
                            TooltipText="Adjust how often you see specific game versions."
                            @bind-Value="PmcVersionWeightingEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcVersionWeightingEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcStandardVersionWeight") ||
                                                MainLayout.pendingChanges.Contains("PmcLeftBehindVersionWeight") ||
                                                MainLayout.pendingChanges.Contains("PmcPrepareForEscapeVersionWeight") ||
                                                MainLayout.pendingChanges.Contains("PmcEdgeOfDarknessVersionWeight") ||
                                                MainLayout.pendingChanges.Contains("PmcUnheardVersionWeight"))"
                            IsNonDefault="@(PmcVersionWeightingEnabled ||
                                            PmcStandardVersionWeight != 20 ||
                                            PmcLeftBehindVersionWeight != 10 ||
                                            PmcPrepareForEscapeVersionWeight != 10 ||
                                            PmcEdgeOfDarknessVersionWeight != 40 ||
                                            PmcUnheardVersionWeight != 20)"
                            OnUndo="UndoPmcVersionWeighting"
                            OnDefault="DefaultPmcVersionWeighting" />

                        <MudSliderChildTT
                            Label="Standard"
                            TooltipText="Higher number is more common. Lower number is more rare. Compare this to the weights of other game versions."
                            @bind-Value="PmcStandardVersionWeight"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcVersionWeightingEnabled)" />

                        <MudSliderChildTT
                            Label="Left Behind"
                            TooltipText="Higher number is more common. Lower number is more rare. Compare this to the weights of other game versions."
                            @bind-Value="PmcLeftBehindVersionWeight"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcVersionWeightingEnabled)" />

                        <MudSliderChildTT
                            Label="Prepare for Escape"
                            TooltipText="Higher number is more common. Lower number is more rare. Compare this to the weights of other game versions."
                            @bind-Value="PmcPrepareForEscapeVersionWeight"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcVersionWeightingEnabled)" />

                        <MudSliderChildTT
                            Label="Edge of Darkness"
                            TooltipText="Higher number is more common. Lower number is more rare. Compare this to the weights of other game versions."
                            @bind-Value="PmcEdgeOfDarknessVersionWeight"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcVersionWeightingEnabled)" />

                        <MudSliderChildTT
                            Label="Unheard Edition"
                            TooltipText="Higher number is more common. Lower number is more rare. Compare this to the weights of other game versions."
                            @bind-Value="PmcUnheardVersionWeight"
                            Min="1"
                            Max="100"
                            Disabled="@(!PmcVersionWeightingEnabled)" />

                    </MudGrid>
                </MudExpansionPanel>

                <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Style="padding-bottom:25px" Text="PMC Plate Class Selection" Expanded="true">
                    <MudGrid>
                        @foreach (var tier in new[] {
                            ("Tier 1 (Lv1-10)",  "Pmc_PlateClass_Tier1", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier1, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier1),
                            ("Tier 2 (Lv11-20)", "Pmc_PlateClass_Tier2", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier2, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier2),
                            ("Tier 3 (Lv21-30)", "Pmc_PlateClass_Tier3", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier3, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier3),
                            ("Tier 4 (Lv31-40)", "Pmc_PlateClass_Tier4", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier4, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier4),
                            ("Tier 5 (Lv41-50)", "Pmc_PlateClass_Tier5", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier5, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier5),
                            ("Tier 6 (Lv51-60)", "Pmc_PlateClass_Tier6", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier6, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier6),
                            ("Tier 7 (Lv61-79)", "Pmc_PlateClass_Tier7", ModConfig.Config.GeneralConfig.PlateClasses.Pmc.Tier7, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.Pmc.Tier7),
                        })
                        {
                            var tierTooltip = $"Adjust the plate class levels for {tier.Item1}. If a plate is selected that cannot fit in the armour, APBS will upgrade the plate level by 1 until it is valid.";
                            var tierDefaults = PmcTierDefaults[tier.Item1];

                            <PlateClassTier
                                TierLabel="@tier.Item1"
                                TooltipText="@tierTooltip"
                                ChangeKeyPrefix="@tier.Item2"
                                FrontValues="@ToDict(tier.Item3["front_plate"])"
                                BackValues="@ToDict(tier.Item3["back_plate"])"
                                LeftValues="@ToDict(tier.Item3["left_side_plate"])"
                                RightValues="@ToDict(tier.Item3["right_side_plate"])"
                                Defaults="@tierDefaults"
                                ValuesChanged="@((e) => HandlePlateChanged(tier.Item2, tier.Item3, tier.Item4, e))"
                                OnUndo="@((pos) => HandlePlateUndo(tier.Item2, tier.Item3, tier.Item4, pos))"
                                OnDefault="@((pos) => HandlePlateDefault(tier.Item2, tier.Item3, pos, tierDefaults))" />
                        }
                    </MudGrid>
                </MudExpansionPanel>

                <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Style="padding-bottom:25px" Text="Nothing to see here..." Expanded="false">
                    <MudGrid>

                        <MudSwitchTT
                            Label="Developer Bots"
                            TooltipText="Flags SPT & APBS Devs as Developers. Also contributors to APBS."
                            @bind-Value="PmcSecretDevelopersNameMarkEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcSecretDevelopersNameMarkEnabled") ||
                                                MainLayout.pendingChanges.Contains("PmcSecretDevelopersNameList"))"
                            IsNonDefault="@(!PmcSecretDevelopersNameMarkEnabled ||
                                            PmcSecretDevelopersNameList.Count != 10 ||
                                            !PmcSecretDevelopersNameList.Contains("Chomp") ||
                                            !PmcSecretDevelopersNameList.Contains("Dirtbikercj") ||
                                            !PmcSecretDevelopersNameList.Contains("Clodan") ||
                                            !PmcSecretDevelopersNameList.Contains("CWX") ||
                                            !PmcSecretDevelopersNameList.Contains("DrakiaXYZ") ||
                                            !PmcSecretDevelopersNameList.Contains("Kaeno") ||
                                            !PmcSecretDevelopersNameList.Contains("Refringe") ||
                                            !PmcSecretDevelopersNameList.Contains("Waffle") ||
                                            !PmcSecretDevelopersNameList.Contains("AcidPhantasm") ||
                                            !PmcSecretDevelopersNameList.Contains("Archangel"))"
                            OnUndo="UndoSecretDeveloperEnabled"
                            OnDefault="DefaultSecretDeveloperEnabled" />

                        <MudItem xs="1">
                            <MudPaper Class="d-flex flex-column align-center justify-center mud-width-full py-2">
                                <MudTooltip Text="Enter the name of the bot you want marked as a developer, then click the arrow (or press enter) to add it." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                    <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                </MudTooltip>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="4" Class="align-center">
                            <MudTextField T="string" @bind-Value="@PmcSecretDevelopersEntryHolder"
                                Typo="Typo.body2" HelperText="Enter valid Bot name"
                                Placeholder="Bot Name"
                                Variant="Variant.Text"
                                Disabled="!PmcSecretDevelopersNameMarkEnabled"
                                OnKeyDown="@((e) => { if (HandleKeyDown(e)) TryAddDeveloperName(); })"
                                Validation="@(new Func<string, IEnumerable<string>>(Utils.StringLengthValidation))"
                                Immediate="true"
                                Adornment="Adornment.End"
                                AdornmentIcon="@Icons.Material.Filled.ArrowRight"
                                OnAdornmentClick="TryAddDeveloperName" />
                        </MudItem>
                        <MudItem xs="6">
                            @foreach (var item in PmcSecretDevelopersNameList)
                            {
                                <MudChip Disabled="!PmcSecretDevelopersNameMarkEnabled" Value="@item" T="string" Color="Color.Default"
                                    OnClose="@(() => {
                                        PmcSecretDevelopersNameList.Remove(item);
                                        Utils.UpdateView(PmcSecretDevelopersNameList, ModConfig.OriginalConfig.PmcBots.Secrets.DeveloperSettings.DevNames.NameList, "PmcSecretDevelopersNameList");
                                    })">@item</MudChip>
                            }
                        </MudItem>

                        <MudDivider DividerType="DividerType.FullWidth" Class="my-3" />

                        <MudSwitchTT
                            Label="Force Developer Bot Levels"
                            TooltipText="Allows enabled developer bots to always spawn within the specified level ranges."
                            @bind-Value="PmcSecretDeveloperLevelsEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("PmcSecretDeveloperLevelsEnabled"))"
                            IsNonDefault="@(PmcSecretDeveloperLevelsEnabled)"
                            OnUndo="UndoSecretDeveloperLevelsEnabled"
                            OnDefault="DefaultSecretDeveloperLevelsEnabled" />

                        <MudItem xs="2" />
                        <MudItem xs="3">
                            <MudTooltip Text="Minimum and maximum levels for bots in the Developer Name list, if enabled." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Developer Bot Level Values</MudText>
                            </MudTooltip>
                        </MudItem>
                        <MudItem xs="6">
                            <MudPaper Class="d-flex align-start mud-width-full" Style="margin-top: -20px;" Elevation="0">
                                <MudTooltip Text="Lowest level that above named bots can be." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                    <MudNumericField Margin="Margin.Dense" HideSpinButtons="true" @bind-Value="PmcSecretDeveloperLevelsMin" Label="Minimum" HelperText="Level" Variant="Variant.Filled"
                                        Min="1" Max="@(PmcSecretDeveloperLevelsMax - 1)" Disabled="!PmcSecretDeveloperLevelsEnabled" />
                                </MudTooltip>
                                <MudSpacer />
                                <MudTooltip Text="Highest level that above named bots can be." Color="Color.Primary" Placement="Placement.Left" Arrow="true">
                                    <MudNumericField Margin="Margin.Dense" HideSpinButtons="true" @bind-Value="PmcSecretDeveloperLevelsMax" Label="Maximum" HelperText="Level" Variant="Variant.Filled"
                                        Min="@(PmcSecretDeveloperLevelsMin + 1)" Max="79" Disabled="!PmcSecretDeveloperLevelsEnabled" />
                                </MudTooltip>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="1">
                            @if (MainLayout.AppUndoButtonToggle && (
                                MainLayout.pendingChanges.Contains("PmcSecretDeveloperLevelsMin") ||
                                MainLayout.pendingChanges.Contains("PmcSecretDeveloperLevelsMax")))
                            {
                                <MudButton @onclick="UndoSecretDeveloperLevelsMinMax" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                            }
                            else if (MainLayout.AppDefaultButtonToggle && (
                                PmcSecretDeveloperLevelsMin != 30 ||
                                PmcSecretDeveloperLevelsMax != 79))
                            {
                                <MudButton @onclick="DefaultSecretDeveloperLevelsMinMax" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                            }
                        </MudItem>

                    </MudGrid>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </MudContainer>
</MudMainContent>

@code {
    #region ENABLE / DISABLE
    private bool PmcEnabled
    {
        get => ModConfig.Config.PmcBots.Enable;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.PmcBots.Enable, nameof(PmcEnabled));
            ModConfig.Config.PmcBots.Enable = value;
        }
    }
    private void UndoPmcBots() => PmcEnabled = ModConfig.OriginalConfig.PmcBots.Enable;
    private void DefaultPmcBots() => PmcEnabled = true;
    #endregion
    #region LOOT
    private bool PmcLootEnabled
    {
        get => ModConfig.Config.PmcBots.LootConfig.Enable;
        set
        {
            ModConfig.Config.PmcBots.LootConfig.Enable = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.PmcBots.LootConfig.Enable, nameof(PmcLootEnabled));
        }
    }
    private List<string> PmcLootBlacklist => ModConfig.Config.PmcBots.LootConfig.Blacklist;
    private void UndoLoot()
    {
        PmcLootEnabled = ModConfig.OriginalConfig.PmcBots.LootConfig.Enable;
        PmcLootBlacklist.Clear();
        foreach (var item in ModConfig.OriginalConfig.PmcBots.LootConfig.Blacklist)
        {
            PmcLootBlacklist.Add(item);
        }
        MainLayout.pendingChanges.Remove("PmcLootEnabled");
        MainLayout.pendingChanges.Remove("PmcLootBlacklist");
    }
    private void DefaultLoot()
    {
        PmcLootEnabled = false;
        PmcLootBlacklist.Clear();
        if (!MainLayout.pendingChanges.Contains("PmcLootEnabled")) MainLayout.pendingChanges.Add("PmcLootEnabled");
