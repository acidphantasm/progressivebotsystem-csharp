    private Dictionary<string, double> ToDict(Dictionary<string, double> source) => new(source);

    private void HandlePlateChanged(string keyPrefix, Dictionary<string, Dictionary<string, double>> config, Dictionary<string, Dictionary<string, double>> original, (string position, string classNum, double value) e)
    {
        config[e.position][e.classNum] = e.value;
        Utils.UpdateView(e.value, original[e.position][e.classNum], $"{keyPrefix}_{e.position}_Class{e.classNum}");
    }

    private void HandlePlateUndo(string keyPrefix, Dictionary<string, Dictionary<string, double>> config, Dictionary<string, Dictionary<string, double>> original, string position)
    {
        foreach (var classNum in new[] { "2", "3", "4", "5", "6" })
        {
            config[position][classNum] = original[position][classNum];
            MainLayout.pendingChanges.Remove($"{keyPrefix}_{position}_Class{classNum}");
        }
        MainLayout.TriggerUIRefresh();
    }

    private void HandlePlateDefault(string keyPrefix, Dictionary<string, Dictionary<string, double>> config, string position, Dictionary<string, double> defaults)
    {
        foreach (var (classNum, value) in defaults)
        {
            config[position][classNum] = value;
            Utils.UpdateView(value, value, $"{keyPrefix}_{position}_Class{classNum}");
        }
        MainLayout.TriggerUIRefresh();
    }
