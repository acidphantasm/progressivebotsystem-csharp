    #region SECRET
    private bool PmcSecretDevelopersNameMarkEnabled
    {
        get => ModConfig.Config.PmcBots.Secrets.DeveloperSettings.DevNames.Enable;
        set
        {
            ModConfig.Config.PmcBots.Secrets.DeveloperSettings.DevNames.Enable = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.PmcBots.Secrets.DeveloperSettings.DevNames.Enable, nameof(PmcSecretDevelopersNameMarkEnabled));
        }
    }
    private string PmcSecretDevelopersEntryHolder { get; set; } = "";
    private List<string> PmcSecretDevelopersNameList => ModConfig.Config.PmcBots.Secrets.DeveloperSettings.DevNames.NameList;

    private void TryAddDeveloperName()
    {
        if (string.IsNullOrEmpty(PmcSecretDevelopersEntryHolder)) return;
        if (PmcSecretDevelopersNameList.Contains(PmcSecretDevelopersEntryHolder))
        {
            Snackbar.Add("Name already added.", Severity.Error, config => { config.ShowCloseIcon = false; });
            return;
        }
        if (!Utils.IsStringAndValidLength(PmcSecretDevelopersEntryHolder))
        {
            Snackbar.Add("Invalid Name.", Severity.Error, config => { config.ShowCloseIcon = false; });
            return;
        }
        PmcSecretDevelopersNameList.Add(PmcSecretDevelopersEntryHolder);
        PmcSecretDevelopersEntryHolder = "";
        Utils.UpdateView(PmcSecretDevelopersNameList, ModConfig.OriginalConfig.PmcBots.Secrets.DeveloperSettings.DevNames.NameList, nameof(PmcSecretDevelopersNameList));
    }

    private void UndoSecretDeveloperEnabled()
    {
        PmcSecretDevelopersNameMarkEnabled = ModConfig.OriginalConfig.PmcBots.Secrets.DeveloperSettings.DevNames.Enable;
        PmcSecretDevelopersNameList.Clear();
        foreach (var item in ModConfig.OriginalConfig.PmcBots.Secrets.DeveloperSettings.DevNames.NameList)
            PmcSecretDevelopersNameList.Add(item);
        MainLayout.pendingChanges.Remove("PmcSecretDevelopersNameMarkEnabled");
        MainLayout.pendingChanges.Remove("PmcSecretDevelopersNameList");
    }
    private void DefaultSecretDeveloperEnabled()
    {
        PmcSecretDevelopersNameMarkEnabled = true;
        PmcSecretDevelopersNameList.Clear();
        foreach (var name in new[] { "Chomp", "Dirtbikercj", "Clodan", "CWX", "DrakiaXYZ", "Kaeno", "Refringe", "Waffle", "AcidPhantasm", "Archangel" })
            PmcSecretDevelopersNameList.Add(name);
        if (!MainLayout.pendingChanges.Contains("PmcSecretDevelopersNameMarkEnabled")) MainLayout.pendingChanges.Add("PmcSecretDevelopersNameMarkEnabled");
        if (!MainLayout.pendingChanges.Contains("PmcSecretDevelopersNameList")) MainLayout.pendingChanges.Add("PmcSecretDevelopersNameList");
    }

