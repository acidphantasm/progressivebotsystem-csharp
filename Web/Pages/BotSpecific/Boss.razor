@page "/progressivebotsystem/boss"
@using _progressiveBotSystem.Web.Components
@layout MainLayout

<MudMainContent>
    <MudContainer Class="mb-20">
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Boss Specific Configuration" Expanded="true">
                <MudGrid>

                    <MudSwitchTTWarning
                        Label="Boss Bot Generation"
                        TooltipText="Grants APBS control over Bosses (including Goons). You will have vanilla versions of these bots if disabled."
                        WarningTooltip1="All settings on this page, and any other setting that may impact these bots are controlled by this toggle."
                        WarningTooltip2="EXCEPTION: Normalize Health is always applied if enabled but not excluded."
                        @bind-Value="BossEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossEnabled"))"
                        IsNonDefault="@(!BossEnabled)"
                        OnUndo="UndoBossBots"
                        OnDefault="DefaultBossBots" />

                </MudGrid>
            </MudExpansionPanel>
            @if (BossEnabled)
            {
                <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Boss Specific Options" Expanded="true">
                    <MudGrid>

                        <MudSwitchTT
                            Label="Loot"
                            TooltipText="Allows Boss Bots to spawn with additional loot."
                            @bind-Value="BossLootEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossLootEnabled") || 
                                                MainLayout.pendingChanges.Contains("_bossLootBlacklist"))"
                            IsNonDefault="@(!BossLootEnabled || 
                                            BossLootBlacklist.Count > 0)"
                            OnUndo="UndoLoot"
                            OnDefault="DefaultLoot" />

                        <LootBlacklistValues
                            Blacklist="BossLootBlacklist"
                            OriginalBlacklist="ModConfig.OriginalConfig.BossBots.LootConfig.Blacklist"
                            ChangeKey="_bossLootBlacklist" />

                        <MudDivider DividerType="DividerType.FullWidth" Class="my-3" />

                        <MudSwitchTT
                            Label="Roll Ammunition Selection Again"
                            TooltipText="Allows Bosses to reroll their selected round from their weapons caliber, max one time per each magazine."
                            @bind-Value="BossWeaponAmmunitionRollEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossWeaponAmmunitionRollEnabled") || 
                                                MainLayout.pendingChanges.Contains("_bossWeaponAmmunitionRollChance"))"
                            IsNonDefault="@(!BossWeaponAmmunitionRollEnabled || 
                                            BossWeaponAmmunitionRollChance != 50)"
                            OnUndo="UndoRollAmmunitionEnabled"
                            OnDefault="DefaultRollAmmunitionEnabled" />
                        
                        <MudSliderTT
                            Label="Roll Again Chance"
                            TooltipText="This is the chance that Bosses will roll for a different round from the same caliber, max one time per each magazine."
                            @bind-Value="BossWeaponAmmunitionRollChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!BossWeaponAmmunitionRollEnabled)" />

                        <MudSwitchTT
                            Label="Toploading"
                            TooltipText="Allows Bosses to top load their extra magazines."
                            @bind-Value="BossWeaponToploadEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossWeaponToploadEnabled") || 
                                                MainLayout.pendingChanges.Contains("_bossWeaponToploadChance") || 
                                                MainLayout.pendingChanges.Contains("_bossWeaponToploadPercent"))"
                            IsNonDefault="@(BossWeaponToploadEnabled || 
                                            BossWeaponToploadChance != 30 || 
                                            BossWeaponToploadPercent != 30)"
                            OnUndo="UndoToploadEnabled"
                            OnDefault="DefaultToploadEnabled" />

                        <MudSliderTT
                            Label="Top load Chance"
                            TooltipText="This is the chance that Bosses will top load their extra magazines."
                            @bind-Value="BossWeaponToploadChance"
                            Min="1"
                            Max="100"
                            Disabled="@(!BossWeaponToploadEnabled)" />

                        <MudSliderTT
                            Label="Top load Percent"
                            TooltipText="This is the percentage of their extra magazines that Bosses will top load."
                            @bind-Value="BossWeaponToploadPercent"
                            Min="10"
                            Max="50"
                            Disabled="@(!BossWeaponToploadEnabled)" />

                        <MudSwitchTT
                            Label="Resource Randomization"
                            TooltipText="Allows random resource consumption on Food/Drink/Medical Items."
                            @bind-Value="BossResourceRandomizationEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossResourceRandomizationEnabled") || 
                                                MainLayout.pendingChanges.Contains("_bossMedRateMaxChance") || 
                                                MainLayout.pendingChanges.Contains("_bossMedRateUsagePercent") || 
                                                MainLayout.pendingChanges.Contains("_bossFoodRateMaxChance") || 
                                                MainLayout.pendingChanges.Contains("_bossFoodRateUsagePercent"))"
                            IsNonDefault="@(!BossResourceRandomizationEnabled || 
                                            BossMedRateMaxChance != 50 || 
                                            BossMedRateUsagePercent != 50 || 
                                            BossFoodRateMaxChance != 50 || 
                                            BossFoodRateUsagePercent != 50)"
                            OnUndo="UndoResourceRandomization"
                            OnDefault="DefaultResourceRandomization" />

                        <MedicalFoodValues
                            @bind-MedMaxChance="BossMedRateMaxChance"
                            @bind-MedUsagePercent="BossMedRateUsagePercent"
                            @bind-FoodMaxChance="BossFoodRateMaxChance"
                            @bind-FoodUsagePercent="BossFoodRateUsagePercent"
                            Disabled="@(!BossResourceRandomizationEnabled)" />

                        <MudSwitchTT
                            Label="Weapon Durability Changes"
                            TooltipText="Allows configurable weapon durability."
                            @bind-Value="BossWeaponDurabilityEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossWeaponDurabilityEnabled") ||
                                               MainLayout.pendingChanges.Contains("_bossWeaponDurabilityMin") ||
                                               MainLayout.pendingChanges.Contains("_bossWeaponDurabilityMax") ||
                                               MainLayout.pendingChanges.Contains("_bossWeaponDurabilityMinDelta") ||
                                               MainLayout.pendingChanges.Contains("_bossWeaponDurabilityMaxDelta") ||
                                               MainLayout.pendingChanges.Contains("_bossWeaponDurabilityEnhancementChance"))"
                            IsNonDefault="@(!BossWeaponDurabilityEnabled ||
                                          BossWeaponDurabilityMin != 90 ||
                                          BossWeaponDurabilityMax != 100 ||
                                          BossWeaponDurabilityMinDelta != 0 ||
                                          BossWeaponDurabilityMaxDelta != 5 ||
                                          BossWeaponDurabilityEnhancementChance != 0)"
                            OnUndo="UndoWeaponDurability"
                            OnDefault="DefaultWeaponDurability" />

                        <DurabilityValues
                            Label="Weapon"
                            @bind-Min="BossWeaponDurabilityMin"
                            @bind-Max="BossWeaponDurabilityMax"
                            @bind-MinDelta="BossWeaponDurabilityMinDelta"
                            @bind-MaxDelta="BossWeaponDurabilityMaxDelta"
                            MinLimitPercent="BossWeaponDurabilityMinLimitPercent"
                            MaxLimitPercent="BossWeaponDurabilityMaxLimitPercent"
                            Validation="ValidateWeaponDelta"
                            Disabled="@(!BossWeaponDurabilityEnabled)" />

                        <MudSliderTT
                            Label="Enhancement Chance"
                            TooltipText="This is the chance that bot weapons have an enhancement applied to them."
                            @bind-Value="BossWeaponDurabilityEnhancementChance"
                            Min="0"
                            Max="100"
                            Disabled="@(!BossWeaponDurabilityEnabled)" />

                        <MudSwitchTT
                            Label="Armour Durability Changes"
                            TooltipText="Allows configurable armour durability."
                            @bind-Value="BossArmourDurabilityEnabled"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("_bossArmourDurabilityEnabled") ||
                                               MainLayout.pendingChanges.Contains("_bossArmourDurabilityMin") ||
                                               MainLayout.pendingChanges.Contains("_bossArmourDurabilityMax") ||
                                               MainLayout.pendingChanges.Contains("_bossArmourDurabilityMinDelta") ||
                                               MainLayout.pendingChanges.Contains("_bossArmourDurabilityMaxDelta"))"
                            IsNonDefault="@(!BossArmourDurabilityEnabled ||
                                          BossArmourDurabilityMin != 90 ||
                                          BossArmourDurabilityMax != 100 ||
                                          BossArmourDurabilityMinDelta != 0 ||
                                          BossArmourDurabilityMaxDelta != 5)"
                            OnUndo="UndoArmourDurability"
                            OnDefault="DefaultArmourDurability" />

                        <DurabilityValues
                            Label="Armour"
                            @bind-Min="BossArmourDurabilityMin"
                            @bind-Max="BossArmourDurabilityMax"
                            @bind-MinDelta="BossArmourDurabilityMinDelta"
                            @bind-MaxDelta="BossArmourDurabilityMaxDelta"
                            MinLimitPercent="BossArmourDurabilityMinLimitPercent"
                            MaxLimitPercent="BossArmourDurabilityMaxLimitPercent"
                            Validation="ValidateArmourDelta"
                            Disabled="@(!BossArmourDurabilityEnabled)" />

                    </MudGrid>
                </MudExpansionPanel>
                <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Style="padding-bottom:25px" Text="Plate Class Selection" Expanded="true">
                    <MudGrid>
                        @foreach (var tier in new[] {
                            ("Tier 1 (Lv1-10)",  "_boss_PlateClass_Tier1", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier1, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier1),
                            ("Tier 2 (Lv11-20)", "_boss_PlateClass_Tier2", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier2, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier2),
                            ("Tier 3 (Lv21-30)", "_boss_PlateClass_Tier3", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier3, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier3),
                            ("Tier 4 (Lv31-40)", "_boss_PlateClass_Tier4", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier4, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier4),
                            ("Tier 5 (Lv41-50)", "_boss_PlateClass_Tier5", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier5, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier5),
                            ("Tier 6 (Lv51-60)", "_boss_PlateClass_Tier6", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier6, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier6),
                            ("Tier 7 (Lv61-79)", "_boss_PlateClass_Tier7", ModConfig.Config.GeneralConfig.PlateClasses.BossAndSpecial.Tier7, ModConfig.OriginalConfig.GeneralConfig.PlateClasses.BossAndSpecial.Tier7),
                        })
                        {
                            var tierTooltip = $"Adjust the plate class levels for {tier.Item1}. If a plate is selected that cannot fit in the armour, APBS will upgrade the plate level by 1 until it is valid.";

                            <PlateClassTier
                                TierLabel="@tier.Item1"
                                TooltipText="@tierTooltip"
                                ChangeKeyPrefix="@tier.Item2"
                                FrontValues="@ToDict(tier.Item3["front_plate"])"
                                BackValues="@ToDict(tier.Item3["back_plate"])"
                                LeftValues="@ToDict(tier.Item3["left_side_plate"])"
                                RightValues="@ToDict(tier.Item3["right_side_plate"])"
                                ValuesChanged="@((e) => HandlePlateChanged(tier.Item2, tier.Item3, tier.Item4, e))"
                                OnUndo="@((pos) => HandlePlateUndo(tier.Item2, tier.Item3, tier.Item4, pos))"
                                OnDefault="@((pos) => HandlePlateDefault(tier.Item2, tier.Item3, pos))" />
                        }

                    </MudGrid>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>
    </MudContainer>
</MudMainContent>

@code {
    #region ENABLE / DISABLE
    private bool BossEnabled
    {
        get => ModConfig.Config.BossBots.Enable;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.Enable);
            ModConfig.Config.BossBots.Enable = value;
        }
    }
    private void UndoBossBots() => BossEnabled = ModConfig.OriginalConfig.BossBots.Enable;
    private void DefaultBossBots() => BossEnabled = true;
    #endregion
    #region LOOT
    private bool BossLootEnabled
    {
        get => ModConfig.Config.BossBots.LootConfig.Enable;
        set
        {
            ModConfig.Config.BossBots.LootConfig.Enable = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.LootConfig.Enable);
        }
    }
    
    private List<string> BossLootBlacklist => ModConfig.Config.BossBots.LootConfig.Blacklist;
    private void UndoLoot()
    {
        BossLootEnabled = ModConfig.OriginalConfig.BossBots.LootConfig.Enable;
        BossLootBlacklist.Clear();
        foreach (var item in ModConfig.OriginalConfig.BossBots.LootConfig.Blacklist)
        {
            BossLootBlacklist.Add(item);
        }
        MainLayout.pendingChanges.Remove("_bossLootBlacklist");
    }

    private void DefaultLoot()
    {
        BossLootEnabled = true;
        BossLootBlacklist.Clear();
        MainLayout.pendingChanges.Add("_bossLootBlacklist");
    }
    #endregion
    #region REROLL
    private bool BossWeaponAmmunitionRollEnabled
    {
        get => ModConfig.Config.BossBots.RerollConfig.Enable;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.RerollConfig.Enable);
            ModConfig.Config.BossBots.RerollConfig.Enable = value;
            ModConfig.Config.BossBots.ToploadConfig.Enable = !value;
        }
    }
    private int BossWeaponAmmunitionRollChance
    {
        get => ModConfig.Config.BossBots.RerollConfig.Chance;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.RerollConfig.Chance);
            ModConfig.Config.BossBots.RerollConfig.Chance = value;
        }
    }
    private void UndoRollAmmunitionEnabled()
    {
        BossWeaponAmmunitionRollEnabled = ModConfig.OriginalConfig.BossBots.RerollConfig.Enable;
        BossWeaponAmmunitionRollChance = ModConfig.OriginalConfig.BossBots.RerollConfig.Chance;
        BossWeaponToploadEnabled = ModConfig.OriginalConfig.BossBots.ToploadConfig.Enable;
        BossWeaponToploadChance = ModConfig.OriginalConfig.BossBots.ToploadConfig.Chance;
        BossWeaponToploadPercent = ModConfig.OriginalConfig.BossBots.ToploadConfig.Percent;
    }
    private void DefaultRollAmmunitionEnabled()
    {
        BossWeaponAmmunitionRollEnabled = true;
        BossWeaponAmmunitionRollChance = 50;
        BossWeaponToploadEnabled = false;
        BossWeaponToploadChance = 30;
        BossWeaponToploadPercent = 30;
    }
    #endregion
    #region TOPLOAD
    private bool BossWeaponToploadEnabled
    {
        get => ModConfig.Config.BossBots.ToploadConfig.Enable;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ToploadConfig.Enable);
            ModConfig.Config.BossBots.ToploadConfig.Enable = value;
            ModConfig.Config.BossBots.RerollConfig.Enable = !value;
        }
    }
    private int BossWeaponToploadChance
    {
        get => ModConfig.Config.BossBots.ToploadConfig.Chance;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ToploadConfig.Chance);
            ModConfig.Config.BossBots.ToploadConfig.Chance = value;
        }
    }
    private int BossWeaponToploadPercent
    {
        get => ModConfig.Config.BossBots.ToploadConfig.Percent;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ToploadConfig.Percent);
            ModConfig.Config.BossBots.ToploadConfig.Percent = value;
        }
    }
    private void UndoToploadEnabled()
    {
        BossWeaponAmmunitionRollEnabled = ModConfig.OriginalConfig.BossBots.RerollConfig.Enable;
        BossWeaponAmmunitionRollChance = ModConfig.OriginalConfig.BossBots.RerollConfig.Chance;
        BossWeaponToploadEnabled = ModConfig.OriginalConfig.BossBots.ToploadConfig.Enable;
        BossWeaponToploadChance = ModConfig.OriginalConfig.BossBots.ToploadConfig.Chance;
        BossWeaponToploadPercent = ModConfig.OriginalConfig.BossBots.ToploadConfig.Percent;
    }
    private void DefaultToploadEnabled()
    {
        BossWeaponAmmunitionRollEnabled = true;
        BossWeaponAmmunitionRollChance = 50;
        BossWeaponToploadEnabled = false;
        BossWeaponToploadChance = 30;
        BossWeaponToploadPercent = 30;
    }
    #endregion
    #region RESOURCE RANDOMIZATION
    private bool BossResourceRandomizationEnabled
    {
        get => ModConfig.Config.BossBots.ResourceRandomization.Enable;
        set
        {
            ModConfig.Config.BossBots.ResourceRandomization.Enable = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ResourceRandomization.Enable);
        }
    }
    private int BossFoodRateMaxChance
    {
        get => ModConfig.Config.BossBots.ResourceRandomization.FoodRateMaxChance;
        set
        {
            ModConfig.Config.BossBots.ResourceRandomization.FoodRateMaxChance = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ResourceRandomization.FoodRateMaxChance);
        }
    }
    private int BossFoodRateUsagePercent
    {
        get => ModConfig.Config.BossBots.ResourceRandomization.FoodRateUsagePercent;
        set
        {
            ModConfig.Config.BossBots.ResourceRandomization.FoodRateUsagePercent = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ResourceRandomization.FoodRateUsagePercent);
        }
    }
    private int BossMedRateMaxChance
    {
        get => ModConfig.Config.BossBots.ResourceRandomization.MedRateMaxChance;
        set
        {
            ModConfig.Config.BossBots.ResourceRandomization.MedRateMaxChance = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ResourceRandomization.MedRateMaxChance);
        }
    }
    private int BossMedRateUsagePercent
    {
        get => ModConfig.Config.BossBots.ResourceRandomization.MedRateUsagePercent;
        set
        {
            ModConfig.Config.BossBots.ResourceRandomization.MedRateUsagePercent = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ResourceRandomization.MedRateUsagePercent);
        }
    }
    private void UndoResourceRandomization()
    {
        BossResourceRandomizationEnabled = ModConfig.OriginalConfig.BossBots.ResourceRandomization.Enable;
        BossFoodRateMaxChance = ModConfig.OriginalConfig.BossBots.ResourceRandomization.FoodRateMaxChance;
        BossFoodRateUsagePercent = ModConfig.OriginalConfig.BossBots.ResourceRandomization.FoodRateUsagePercent;
        BossMedRateMaxChance = ModConfig.OriginalConfig.BossBots.ResourceRandomization.MedRateMaxChance;
        BossMedRateUsagePercent = ModConfig.OriginalConfig.BossBots.ResourceRandomization.MedRateUsagePercent;
    }
    private void DefaultResourceRandomization()
    {
        BossResourceRandomizationEnabled = true;
        BossFoodRateMaxChance = 50;
        BossFoodRateUsagePercent = 50;
        BossMedRateMaxChance = 50;
        BossMedRateUsagePercent = 50;
    }
    #endregion
    #region DURABILITY
    private bool BossWeaponDurabilityEnabled
    {
        get => ModConfig.Config.BossBots.WeaponDurability.Enable;
        set
        {
            ModConfig.Config.BossBots.WeaponDurability.Enable = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.WeaponDurability.Enable);
        }
    }
    private int BossWeaponDurabilityMin
    {
        get => ModConfig.Config.BossBots.WeaponDurability.Min;
        set
        {
            ModConfig.Config.BossBots.WeaponDurability.MinLimitPercent = value - ModConfig.Config.BossBots.WeaponDurability.MaxDelta;
            ModConfig.Config.BossBots.WeaponDurability.Min = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.WeaponDurability.Min);
        }
    }
    private int BossWeaponDurabilityMax
    {
        get => ModConfig.Config.BossBots.WeaponDurability.Max;
        set
        {
            ModConfig.Config.BossBots.WeaponDurability.Max = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.WeaponDurability.Max);
        }
    }
    private int BossWeaponDurabilityMinDelta
    {
        get => ModConfig.Config.BossBots.WeaponDurability.MinDelta;
        set
        {
            ModConfig.Config.BossBots.WeaponDurability.MinDelta = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.WeaponDurability.MinDelta);
        }
    }
    private int BossWeaponDurabilityMaxDelta
    {
        get => ModConfig.Config.BossBots.WeaponDurability.MaxDelta;
        set
        {
            ModConfig.Config.BossBots.WeaponDurability.MinLimitPercent = ModConfig.Config.BossBots.WeaponDurability.Min - value;
            ModConfig.Config.BossBots.WeaponDurability.MaxDelta = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.WeaponDurability.MaxDelta);
        }
    }
    private int BossWeaponDurabilityMinLimitPercent => ModConfig.Config.BossBots.WeaponDurability.MinLimitPercent;
    private int BossWeaponDurabilityMaxLimitPercent => ModConfig.Config.BossBots.WeaponDurability.Max - ModConfig.Config.BossBots.WeaponDurability.MinDelta;
    private int BossWeaponDurabilityEnhancementChance
    {
        get => ModConfig.Config.BossBots.WeaponDurability.EnhancementChance;
        set
        {
            ModConfig.Config.BossBots.WeaponDurability.EnhancementChance = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.WeaponDurability.EnhancementChance);
        }
    }
    private void UndoWeaponDurability()
    {
        BossWeaponDurabilityEnabled = ModConfig.OriginalConfig.BossBots.WeaponDurability.Enable;
        BossWeaponDurabilityMin = ModConfig.OriginalConfig.BossBots.WeaponDurability.Min;
        BossWeaponDurabilityMax = ModConfig.OriginalConfig.BossBots.WeaponDurability.Max;
        BossWeaponDurabilityMinDelta = ModConfig.OriginalConfig.BossBots.WeaponDurability.MinDelta;
        BossWeaponDurabilityMaxDelta = ModConfig.OriginalConfig.BossBots.WeaponDurability.MaxDelta;
        BossWeaponDurabilityEnhancementChance = ModConfig.OriginalConfig.BossBots.WeaponDurability.EnhancementChance;
    }
    private void DefaultWeaponDurability()
    {
        BossWeaponDurabilityEnabled = true;
        BossWeaponDurabilityMin = 90;
        BossWeaponDurabilityMax = 100;
        BossWeaponDurabilityMinDelta = 0;
        BossWeaponDurabilityMaxDelta = 5;
        BossWeaponDurabilityEnhancementChance = 0;
    }
    private bool BossArmourDurabilityEnabled
    {
        get => ModConfig.Config.BossBots.ArmourDurability.Enable;
        set
        {
            ModConfig.Config.BossBots.ArmourDurability.Enable = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ArmourDurability.Enable);
        }
    }
    private int BossArmourDurabilityMin
    {
        get => ModConfig.Config.BossBots.ArmourDurability.Min;
        set
        {
            ModConfig.Config.BossBots.ArmourDurability.MinLimitPercent = value - ModConfig.Config.BossBots.ArmourDurability.MaxDelta;
            ModConfig.Config.BossBots.ArmourDurability.Min = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ArmourDurability.Min);
        }
    }
    private int BossArmourDurabilityMax
    {
        get => ModConfig.Config.BossBots.ArmourDurability.Max;
        set
        {
            ModConfig.Config.BossBots.ArmourDurability.Max = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ArmourDurability.Max);
        }
    }
    private int BossArmourDurabilityMinDelta
    {
        get => ModConfig.Config.BossBots.ArmourDurability.MinDelta;
        set
        {
            ModConfig.Config.BossBots.ArmourDurability.MinDelta = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ArmourDurability.MinDelta);
        }
    }
    private int BossArmourDurabilityMaxDelta
    {
        get => ModConfig.Config.BossBots.ArmourDurability.MaxDelta;
        set
        {
            ModConfig.Config.BossBots.ArmourDurability.MinLimitPercent = ModConfig.Config.BossBots.ArmourDurability.Min - value;
            ModConfig.Config.BossBots.ArmourDurability.MaxDelta = value;
            Utils.UpdateView(value, ModConfig.OriginalConfig.BossBots.ArmourDurability.MaxDelta);
        }
    }
    private int BossArmourDurabilityMinLimitPercent => ModConfig.Config.BossBots.ArmourDurability.MinLimitPercent;
    private int BossArmourDurabilityMaxLimitPercent => ModConfig.Config.BossBots.ArmourDurability.Max - ModConfig.Config.BossBots.ArmourDurability.MinDelta;
    private void UndoArmourDurability()
    {
        BossArmourDurabilityEnabled = ModConfig.OriginalConfig.BossBots.ArmourDurability.Enable;
        BossArmourDurabilityMin = ModConfig.OriginalConfig.BossBots.ArmourDurability.Min;
        BossArmourDurabilityMax = ModConfig.OriginalConfig.BossBots.ArmourDurability.Max;
        BossArmourDurabilityMinDelta = ModConfig.OriginalConfig.BossBots.ArmourDurability.MinDelta;
        BossArmourDurabilityMaxDelta = ModConfig.OriginalConfig.BossBots.ArmourDurability.MaxDelta;
    }
    private void DefaultArmourDurability()
    {
        BossArmourDurabilityEnabled = true;
        BossArmourDurabilityMin = 90;
        BossArmourDurabilityMax = 100;
        BossArmourDurabilityMinDelta = 0;
        BossArmourDurabilityMaxDelta = 5;
    }
    #endregion
    #region PlateClasses
    private Dictionary<string, double> ToDict(Dictionary<string, double> source) => new(source);

    private void HandlePlateChanged(string keyPrefix, Dictionary<string, Dictionary<string, double>> config, Dictionary<string, Dictionary<string, double>> original, (string position, string classNum, double value) e) 
    {
        config[e.position][e.classNum] = e.value;
        Utils.UpdateView(e.value, original[e.position][e.classNum], $"{keyPrefix}_{e.position}_Class{e.classNum}");
    }

    private void HandlePlateUndo(string keyPrefix, Dictionary<string, Dictionary<string, double>> config, Dictionary<string, Dictionary<string, double>> original, string position)
    {
        foreach (var classNum in new[] { "2", "3", "4", "5", "6" })
        {
            config[position][classNum] = original[position][classNum];
            MainLayout.pendingChanges.Remove($"{keyPrefix}_{position}_Class{classNum}");
        }
        MainLayout.TriggerUIRefresh();
    }

    private void HandlePlateDefault(string keyPrefix, Dictionary<string, Dictionary<string, double>> config, string position)
    {
        var defaults = new Dictionary<string, double>
            { {"2", 0}, {"3", 10}, {"4", 50}, {"5", 35}, {"6", 5} };

        foreach (var (classNum, value) in defaults)
        {
            config[position][classNum] = value;
            Utils.UpdateView(value, value, $"{keyPrefix}_{position}_Class{classNum}");
        }
        MainLayout.TriggerUIRefresh();
    }
    #endregion

    #region INPUT HANDLING
    public bool ValidateWeaponDelta(int value)
    {
        return BossWeaponDurabilityMinLimitPercent < BossWeaponDurabilityMaxLimitPercent;
    }

    public bool ValidateArmourDelta(int value)
    {
        return BossArmourDurabilityMinLimitPercent < BossArmourDurabilityMaxLimitPercent;
    }
    #endregion

    #region CASCADING PARAMETERS
    [CascadingParameter] public MainLayout? Layout { get; set; }
    #endregion
}