@page "/progressivebotsystem/modcompatibility"
@using _progressiveBotSystem.Web.Components
@layout MainLayout

<MudMainContent>
    <MudContainer Class="mb-20">
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Custom Item Importing" Expanded="true">
                <MudGrid>

                    <MudSwitchTT
                        Label="Modded Weapons"
                        TooltipText="Allows bots to use custom modded weapons."
                        @bind-Value="ModCustomWeaponsEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomWeaponsEnabled"))"
                        IsNonDefault="@(ModCustomWeaponsEnabled)"
                        OnUndo="UndoCustomWeapons"
                        OnDefault="DefaultCustomWeapons" />

                    <MudSliderChildUndoDefaultTT
                        Label="PMC Weapon Weights"
                        TooltipText="Higher number is more common. If you import a lot of custom weapons, and see them often - try a lower number."
                        @bind-Value="ModPmcWeaponWeights"
                        Min="1"
                        Max="25"
                        Disabled="@(!ModCustomWeaponsEnabled)" 
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomWeaponsEnabled"))"
                        IsNonDefault="@(ModPmcWeaponWeights != 8)"
                        OnUndo="UndoPmcWeaponWeights"
                        OnDefault="DefaultPmcWeaponWeights" />

                    <MudSliderChildUndoDefaultTT
                        Label="Scav Weapon Weights"
                        TooltipText="Higher number is more common. If you import a lot of custom weapons, and see them often - try a lower number."
                        @bind-Value="ModScavWeaponWeights"
                        Min="1"
                        Max="25"
                        Disabled="@(!ModCustomWeaponsEnabled)" 
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomWeaponsEnabled"))"
                        IsNonDefault="@(ModScavWeaponWeights != 1)"
                        OnUndo="UndoScavWeaponWeights"
                        OnDefault="DefaultScavWeaponWeights" />

                    <MudSliderChildUndoDefaultTT
                        Label="Guard Weapon Weights"
                        TooltipText="Higher number is more common. If you import a lot of custom weapons, and see them often - try a lower number."
                        @bind-Value="ModFollowerWeaponWeights"
                        Min="1"
                        Max="25"
                        Disabled="@(!ModCustomWeaponsEnabled)" 
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModFollowerWeaponWeights"))"
                        IsNonDefault="@(ModFollowerWeaponWeights != 6)"
                        OnUndo="UndoFollowerWeaponWeights"
                        OnDefault="DefaultFollowerWeaponWeights" />

                    <MudSwitchTT
                        Label="Modded Equipment"
                        TooltipText="Allows bots to use custom modded equipment."
                        @bind-Value="ModCustomEquipmentEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomEquipmentEnabled"))"
                        IsNonDefault="@(ModCustomEquipmentEnabled)"
                        OnUndo="UndoCustomEquipment"
                        OnDefault="DefaultCustomEquipment" />

                    <MudSwitchTTDisabledWarning
                        Label="Modded Clothing"
                        TooltipText="Allows bots to use custom modded clothing."
                        WarningTooltip1="Automatically disabled if PMC Seasonal Appearance is enabled."
                        WarningTooltip2=""
                        @bind-Value="ModCustomClothingEnabled"
                        Disabled="@(EnableSeasonalPmcAppearance)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomClothingEnabled"))"
                        IsNonDefault="@(ModCustomClothingEnabled)"
                        OnUndo="UndoCustomClothing"
                        OnDefault="DefaultCustomClothing" />

                    <MudSwitchTTWarning
                        Label="Modded Attachments"
                        TooltipText="Allows bots to use custom modded attachments."
                        WarningTooltip1="This puts mod attachments on vanilla weapons. Expect additional RAM usage on the server and longer import times."
                        WarningTooltip2=""
                        @bind-Value="ModCustomAttachmentsEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomAttachmentsEnabled"))"
                        IsNonDefault="@(ModCustomAttachmentsEnabled)"
                        OnUndo="UndoCustomAttachments"
                        OnDefault="DefaultCustomAttachments" />

                    <MudSliderDisabledTT
                        Label="Tier Appearance Level"
                        TooltipText="Tier that custom weapons & equipment will start appearing on bots."
                        @bind-Value="ModInitialTierAppearance"
                        Min="1"
                        Max="7"
                        Disabled="@(!ModCustomWeaponsEnabled && !ModCustomEquipmentEnabled)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModInitialTierAppearance"))"
                        IsNonDefault="@(ModInitialTierAppearance != 3)"
                        OnUndo="UndoInitialTierAppearance"
                        OnDefault="DefaultInitialTierAppearance" />

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Compatibility Options" Expanded="true">
                <MudGrid>

                    <MudSwitchTT
                        Label="Vanilla Cursing Safeguard"
                        TooltipText="Prevents vanilla mods being added to vanilla attachments due to custom item filters."
                        @bind-Value="ModSafeGuardEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModSafeGuardEnabled"))"
                        IsNonDefault="@(!ModSafeGuardEnabled)"
                        OnUndo="UndoSafeGuard"
                        OnDefault="DefaultSafeGuard" />

                    <MudSwitchTTWarning
                        Label="MPR45 Canted Mount Safeguard"
                        TooltipText="Enabling this means if a modded item has a NcSTAR MPR45 in a slot, only allow the MPR45 to be in that slot."
                        WarningTooltip1="If you disable this, all Optical Devices will still be removed - but tactical devices will be allowed (they may block vision)."
                        WarningTooltip2=""
                        @bind-Value="ModMprSafeGuardEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModMprSafeGuardEnabled"))"
                        IsNonDefault="@(!ModMprSafeGuardEnabled)"
                        OnUndo="UndoMprSafeGuard"
                        OnDefault="DefaultMprSafeGuard" />

                    <MudSwitchTTWarning
                        Label="Unlootable Belts on PMCs"
                        TooltipText="Makes belts on PMCs in ArmBand slot unlootable, you can still view contents."
                        WarningTooltip1="Pack'N'Strap Only."
                        WarningTooltip2=""
                        @bind-Value="ModPackNStrapCompatibility"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModPackNStrapCompatibility"))"
                        IsNonDefault="@(!ModPackNStrapCompatibility)"
                        OnUndo="UndoPackNStrap"
                        OnDefault="DefaultPackNStrap" />

                    <MudSwitchTTWarning
                        Label="WTT Backport Dogtags"
                        TooltipText="Allows PMCs to spawn with WTT Backport Dogtags."
                        WarningTooltip1="WTT Backport Only."
                        WarningTooltip2=""
                        @bind-Value="ModWttBackportDogtags"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModWttBackportDogtags"))"
                        IsNonDefault="@(!ModWttBackportDogtags)"
                        OnUndo="UndoWttBackportDogtags"
                        OnDefault="DefaultWttBackportDogtags" />

                    <MudSwitchTTWarning
                        Label="WTT Armoury Bosses Have Variants"
                        TooltipText="Allows Bosses to also get the weapons that WTT intends for them. If disabled, they will only go to Pmcs, scavs, and guards."
                        WarningTooltip1="WTT Armoury Only."
                        WarningTooltip2=""
                        @bind-Value="ModWttArmouryBossVariantsOnBosses"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModWttArmouryBossVariantsOnBosses"))"
                        IsNonDefault="@(!ModWttArmouryBossVariantsOnBosses)"
                        OnUndo="UndoWttArmouryBosses"
                        OnDefault="DefaultArmouryBosses" />

                    <MudSwitchTTWarning
                        Label="WTT Armoury Others Have Variants"
                        TooltipText="Enabling this will also allow other bots to get those weapons. If disabled then they will only go to the bosses WTT has dictated."
                        WarningTooltip1="WTT Armoury Only."
                        WarningTooltip2=""
                        @bind-Value="ModWttArmouryBossVariantsOnOthers"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModWttArmouryBossVariantsOnOthers"))"
                        IsNonDefault="@(!ModWttArmouryBossVariantsOnOthers)"
                        OnUndo="UndoWttArmouryOthers"
                        OnDefault="DefaultWttArmouryOthers" />

                    <MudSwitchTTWarning
                        Label="Add Gas Masks to Bots"
                        TooltipText="Allows bots to use gas masks - if you don't use Hazard Zones then you don't need this."
                        WarningTooltip1="Realism Only."
                        WarningTooltip2=""
                        @bind-Value="ModRealismCompatibility"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModRealismCompatibility"))"
                        IsNonDefault="@(ModRealismCompatibility)"
                        OnUndo="UndoRealism"
                        OnDefault="DefaultRealism" />

                    <MudItem xs="1">
                        <MudPaper Class="d-flex justify-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <ChildContent>
                                    <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                </ChildContent>
                                <TooltipContent>
                                    <MudText Typo="Typo.caption">If you have a mod that increases the max stack size of ammo, you may need to adjust this.</MudText><MudSpacer />
                                    <MudText Typo="Typo.caption">If the stack size of ammo is 10x higher than normal, then set this to 10% of normal.</MudText><MudSpacer />
                                    <MudText Typo="Typo.caption">Example: Mod changes ammo stacks to 600 - you need to set this to 2, so they get 2 stacks of 600 instead of 20 stacks of 600.</MudText><MudSpacer />
                                    <MudText Typo="Typo.caption">Do NOT mess with this unless you need it - it may cause bots to run out of ammo.</MudText>
                                </TooltipContent>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Changes the amount of ammo stacks that get added to bot secure containers." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Bot Secure Container Ammo Stack Count</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">@ModAmmoStackCount</MudButton>
                    </MudItem>
                    <MudItem xs="5">
                        <MudSlider @bind-Value="ModAmmoStackCount" ValueLabel="true" Min="1" Max="30" Color="Color.Info" Size="Size.Medium" />
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.AppUndoButtonToggle && MainLayout.pendingChanges.Contains("ModAmmoStackCount"))
                        {
                            <MudButton @onclick="UndoAmmoStackCount" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (MainLayout.AppDefaultButtonToggle && ModAmmoStackCount != 20)
                        {
                            <MudButton @onclick="DefaultAmmoStackCount" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Debug" Expanded="false">
                <MudGrid>

                    <MudSwitchTTWarning
                        Label="Debug Logging"
                        TooltipText="Do you really need this? Maybe...you're an early release tester?"
                        WarningTooltip1="Enables debug logs in \user\mods\acidphantasm-progressivebotsystem\logs\debug.log"
                        WarningTooltip2=""
                        @bind-Value="DebugLogging"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("DebugLogging"))"
                        IsNonDefault="@(DebugLogging)"
                        OnUndo="UndoDebug"
                        OnDefault="DefaultDebug" />

                    <MudSwitchTTWarning
                        Label="Bot Equipment Logging"
                        TooltipText="Enable or disable Bot Equipment logging for APBS. Very miniscule performance decrease when enabled."
                        WarningTooltip1="Enables bot equipment logs in \user\mods\acidphantasm-progressivebotsystem\logs\*_generation.log"
                        WarningTooltip2=""
                        @bind-Value="BotEquipmentLogging"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("BotEquipmentLogging"))"
                        IsNonDefault="@(!BotEquipmentLogging)"
                        OnUndo="UndoBotLog"
                        OnDefault="DefaultBotLog" />

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Style="padding-bottom:25px" Text="Nothing to see here..." Expanded="false">
                <MudGrid>

                    <MudSwitchTT
                        Label="April Fool's Event"
                        TooltipText="Active: April 1. It inverts the tiering."
                        @bind-Value="EventsAprilFools"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("EventsAprilFools"))"
                        IsNonDefault="@(!EventsAprilFools)"
                        OnUndo="UndoAprilFools"
                        OnDefault="DefaultAprilFools" />

                    <MudSwitchTT
                        Label="Halloween Event"
                        TooltipText="Active: October 31. All bots get pumpkin heads."
                        @bind-Value="EventsHalloween"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("EventsHalloween"))"
                        IsNonDefault="@(!EventsHalloween)"
                        OnUndo="UndoHalloween"
                        OnDefault="DefaultHalloween" />

                    <MudSwitchTT
                        Label="Christmas Event"
                        TooltipText="Active: December 24-25. All bots get Killa's Christmas Helmet and Armour."
                        @bind-Value="EventsChristmas"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("EventsChristmas"))"
                        IsNonDefault="@(!EventsChristmas)"
                        OnUndo="UndoChristmas"
                        OnDefault="DefaultChristmas" />

                </MudGrid>
            </MudExpansionPanel>
        </MudExpansionPanels>
    </MudContainer>
</MudMainContent>

@code {
    #region ENABLE/DISABLE TYPES
    private bool ModCustomWeaponsEnabled
    {
        get => ModConfig.Config.CompatibilityConfig.EnableModdedWeapons;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedWeapons, nameof(ModCustomWeaponsEnabled));
            ModConfig.Config.CompatibilityConfig.EnableModdedWeapons = value;
        }
    }
    private void UndoCustomWeapons() => ModCustomWeaponsEnabled = ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedWeapons;
    private void DefaultCustomWeapons() => ModCustomWeaponsEnabled = false;

    private bool ModCustomEquipmentEnabled
    {
        get => ModConfig.Config.CompatibilityConfig.EnableModdedEquipment;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedEquipment, nameof(ModCustomEquipmentEnabled));
            ModConfig.Config.CompatibilityConfig.EnableModdedEquipment = value;
        }
    }
    private void UndoCustomEquipment() => ModCustomEquipmentEnabled = ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedEquipment;
    private void DefaultCustomEquipment() => ModCustomEquipmentEnabled = false;

    private bool ModCustomClothingEnabled
    {
        get => ModConfig.Config.CompatibilityConfig.EnableModdedClothing;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedClothing, nameof(ModCustomClothingEnabled));
            ModConfig.Config.CompatibilityConfig.EnableModdedClothing = value;
        }
    }
    private void UndoCustomClothing() => ModCustomClothingEnabled = ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedClothing;
    private void DefaultCustomClothing() => ModCustomClothingEnabled = false;

    private bool ModCustomAttachmentsEnabled
    {
        get => ModConfig.Config.CompatibilityConfig.EnableModdedAttachments;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedAttachments, nameof(ModCustomAttachmentsEnabled));
            ModConfig.Config.CompatibilityConfig.EnableModdedAttachments = value;
        }
    }
    private void UndoCustomAttachments() => ModCustomAttachmentsEnabled = ModConfig.OriginalConfig.CompatibilityConfig.EnableModdedAttachments;
    private void DefaultCustomAttachments() => ModCustomAttachmentsEnabled = false;
    #endregion

    #region WEIGHTS / APPEARANCE
    private int ModPmcWeaponWeights
    {
        get => ModConfig.Config.CompatibilityConfig.PmcWeaponWeights;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.PmcWeaponWeights, nameof(ModPmcWeaponWeights));
            ModConfig.Config.CompatibilityConfig.PmcWeaponWeights = value;
        }
    }
    private void UndoPmcWeaponWeights() => ModPmcWeaponWeights = ModConfig.OriginalConfig.CompatibilityConfig.PmcWeaponWeights;
    private void DefaultPmcWeaponWeights() => ModPmcWeaponWeights = 8;

    private int ModScavWeaponWeights
    {
        get => ModConfig.Config.CompatibilityConfig.ScavWeaponWeights;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.ScavWeaponWeights, nameof(ModScavWeaponWeights));
            ModConfig.Config.CompatibilityConfig.ScavWeaponWeights = value;
        }
    }
    private void UndoScavWeaponWeights() => ModScavWeaponWeights = ModConfig.OriginalConfig.CompatibilityConfig.ScavWeaponWeights;
    private void DefaultScavWeaponWeights() => ModScavWeaponWeights = 1;

    private int ModFollowerWeaponWeights
    {
        get => ModConfig.Config.CompatibilityConfig.FollowerWeaponWeights;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.FollowerWeaponWeights, nameof(ModFollowerWeaponWeights));
            ModConfig.Config.CompatibilityConfig.FollowerWeaponWeights = value;
        }
    }
    private void UndoFollowerWeaponWeights() => ModFollowerWeaponWeights = ModConfig.OriginalConfig.CompatibilityConfig.FollowerWeaponWeights;
    private void DefaultFollowerWeaponWeights() => ModFollowerWeaponWeights = 6;

    private int ModInitialTierAppearance
    {
        get => ModConfig.Config.CompatibilityConfig.InitalTierAppearance;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.InitalTierAppearance, nameof(ModInitialTierAppearance));
            ModConfig.Config.CompatibilityConfig.InitalTierAppearance = value;
        }
    }
    private void UndoInitialTierAppearance() => ModInitialTierAppearance = ModConfig.OriginalConfig.CompatibilityConfig.InitalTierAppearance;
    private void DefaultInitialTierAppearance() => ModInitialTierAppearance = 3;
    #endregion

    #region COMPATIBILITY SETTINGS
    private bool ModSafeGuardEnabled
    {
        get => ModConfig.Config.CompatibilityConfig.EnableSafeGuard;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.EnableSafeGuard, nameof(ModSafeGuardEnabled));
            ModConfig.Config.CompatibilityConfig.EnableSafeGuard = value;
        }
    }
    private void UndoSafeGuard() => ModSafeGuardEnabled = ModConfig.OriginalConfig.CompatibilityConfig.EnableSafeGuard;
    private void DefaultSafeGuard() => ModSafeGuardEnabled = true;

    private bool ModMprSafeGuardEnabled
    {
        get => ModConfig.Config.CompatibilityConfig.EnableMprSafeGuard;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.EnableMprSafeGuard, nameof(ModMprSafeGuardEnabled));
            ModConfig.Config.CompatibilityConfig.EnableMprSafeGuard = value;
        }
    }
    private void UndoMprSafeGuard() => ModMprSafeGuardEnabled = ModConfig.OriginalConfig.CompatibilityConfig.EnableMprSafeGuard;
    private void DefaultMprSafeGuard() => ModMprSafeGuardEnabled = true;

    private bool ModPackNStrapCompatibility
    {
        get => ModConfig.Config.CompatibilityConfig.PackNStrapUnlootablePmcArmbandBelts;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.PackNStrapUnlootablePmcArmbandBelts, nameof(ModPackNStrapCompatibility));
            ModConfig.Config.CompatibilityConfig.PackNStrapUnlootablePmcArmbandBelts = value;
        }
    }
    private void UndoPackNStrap() => ModPackNStrapCompatibility = ModConfig.OriginalConfig.CompatibilityConfig.PackNStrapUnlootablePmcArmbandBelts;
    private void DefaultPackNStrap() => ModPackNStrapCompatibility = true;

    private bool ModWttBackportDogtags
    {
        get => ModConfig.Config.CompatibilityConfig.WttBackPortAllowDogtags;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.WttBackPortAllowDogtags, nameof(ModWttBackportDogtags));
            ModConfig.Config.CompatibilityConfig.WttBackPortAllowDogtags = value;
        }
    }
    private void UndoWttBackportDogtags() => ModWttBackportDogtags = ModConfig.OriginalConfig.CompatibilityConfig.WttBackPortAllowDogtags;
    private void DefaultWttBackportDogtags() => ModWttBackportDogtags = true;

    private bool ModWttArmouryBossVariantsOnBosses
    {
        get => ModConfig.Config.CompatibilityConfig.WttArmouryAddBossVariantsToBosses;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.WttArmouryAddBossVariantsToBosses, nameof(ModWttArmouryBossVariantsOnBosses));
            ModConfig.Config.CompatibilityConfig.WttArmouryAddBossVariantsToBosses = value;
        }
    }
    private void UndoWttArmouryBosses() => ModWttArmouryBossVariantsOnBosses = ModConfig.OriginalConfig.CompatibilityConfig.WttArmouryAddBossVariantsToBosses;
    private void DefaultArmouryBosses() => ModWttArmouryBossVariantsOnBosses = true;

    private bool ModWttArmouryBossVariantsOnOthers
    {
        get => ModConfig.Config.CompatibilityConfig.WttArmouryAddBossVariantsToOthers;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.WttArmouryAddBossVariantsToOthers, nameof(ModWttArmouryBossVariantsOnOthers));
            ModConfig.Config.CompatibilityConfig.WttArmouryAddBossVariantsToOthers = value;
        }
    }
    private void UndoWttArmouryOthers() => ModWttArmouryBossVariantsOnOthers = ModConfig.OriginalConfig.CompatibilityConfig.WttArmouryAddBossVariantsToOthers;
    private void DefaultWttArmouryOthers() => ModWttArmouryBossVariantsOnOthers = true;

    private bool ModRealismCompatibility
    {
        get => ModConfig.Config.CompatibilityConfig.RealismAddGasMasksToBots;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.RealismAddGasMasksToBots, nameof(ModRealismCompatibility));
            ModConfig.Config.CompatibilityConfig.RealismAddGasMasksToBots = value;
        }
    }
    private void UndoRealism() => ModRealismCompatibility = ModConfig.OriginalConfig.CompatibilityConfig.RealismAddGasMasksToBots;
    private void DefaultRealism() => ModRealismCompatibility = false;

    private int ModAmmoStackCount
    {
        get => ModConfig.Config.CompatibilityConfig.GeneralSecureContainerAmmoStacks;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.GeneralSecureContainerAmmoStacks, nameof(ModAmmoStackCount));
            ModConfig.Config.CompatibilityConfig.GeneralSecureContainerAmmoStacks = value;
        }
    }
    private void UndoAmmoStackCount() => ModAmmoStackCount = ModConfig.OriginalConfig.CompatibilityConfig.GeneralSecureContainerAmmoStacks;
    private void DefaultAmmoStackCount() => ModAmmoStackCount = 20;
    #endregion

    #region DEBUG
    private bool DebugLogging
    {
        get => ModConfig.Config.EnableDebugLog;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.EnableDebugLog, nameof(DebugLogging));
            ModConfig.Config.EnableDebugLog = value;
        }
    }
    private void UndoDebug() => DebugLogging = ModConfig.OriginalConfig.EnableDebugLog;
    private void DefaultDebug() => DebugLogging = false;

    private bool BotEquipmentLogging
    {
        get => ModConfig.Config.EnableBotEquipmentLog;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.EnableBotEquipmentLog, nameof(BotEquipmentLogging));
            ModConfig.Config.EnableBotEquipmentLog = value;
        }
    }
    private void UndoBotLog() => BotEquipmentLogging = ModConfig.OriginalConfig.EnableBotEquipmentLog;
    private void DefaultBotLog() => BotEquipmentLogging = false;
    #endregion

    #region SECRETS
    private bool EventsAprilFools
    {
        get => ModConfig.Config.CompatibilityConfig.Secrets.AprilFoolsEvent;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.Secrets.AprilFoolsEvent, nameof(EventsAprilFools));
            ModConfig.Config.CompatibilityConfig.Secrets.AprilFoolsEvent = value;
        }
    }
    private void UndoAprilFools() => EventsAprilFools = ModConfig.OriginalConfig.CompatibilityConfig.Secrets.AprilFoolsEvent;
    private void DefaultAprilFools() => EventsAprilFools = true;

    private bool EventsHalloween
    {
        get => ModConfig.Config.CompatibilityConfig.Secrets.HalloweenEvent;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.Secrets.HalloweenEvent, nameof(EventsHalloween));
            ModConfig.Config.CompatibilityConfig.Secrets.HalloweenEvent = value;
        }
    }
    private void UndoHalloween() => EventsHalloween = ModConfig.OriginalConfig.CompatibilityConfig.Secrets.HalloweenEvent;
    private void DefaultHalloween() => EventsHalloween = true;

    private bool EventsChristmas
    {
        get => ModConfig.Config.CompatibilityConfig.Secrets.ChristmasEvent;
        set
        {
            Utils.UpdateView(value, ModConfig.OriginalConfig.CompatibilityConfig.Secrets.ChristmasEvent, nameof(EventsChristmas));
            ModConfig.Config.CompatibilityConfig.Secrets.ChristmasEvent = value;
        }
    }
    private void UndoChristmas() => EventsChristmas = ModConfig.OriginalConfig.CompatibilityConfig.Secrets.ChristmasEvent;
    private void DefaultChristmas() => EventsChristmas = true;
    #endregion

    #region GETTER FOR DELEGATES NOT HERE
    private bool EnableSeasonalPmcAppearance => ModConfig.Config.PmcBots.AdditionalOptions.SeasonalPmcAppearance;
    #endregion

    #region CASCADING PARAMETERS
    [CascadingParameter] public MainLayout? Layout { get; set; }
    #endregion
}