                        {
                            <MudButton @onclick="DefaultAmmoStackCount" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Debug" Expanded="false">
                <MudGrid>

                    <MudSwitchTTWarning
                        Label="Debug Logging"
                        TooltipText="Do you really need this? Maybe...you're an early release tester?"
                        WarningTooltip1="Enables debug logs in \user\mods\acidphantasm-progressivebotsystem\logs\debug.log"
                        WarningTooltip2=""
                        @bind-Value="DebugLogging"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("DebugLogging"))"
                        IsNonDefault="@(DebugLogging)"
                        OnUndo="UndoDebug"
                        OnDefault="DefaultDebug" />

                    <MudSwitchTTWarning
                        Label="Bot Equipment Logging"
                        TooltipText="Enable or disable Bot Equipment logging for APBS. Very miniscule performance decrease when enabled."
                        WarningTooltip1="Enables bot equipment logs in \user\mods\acidphantasm-progressivebotsystem\logs\*_generation.log"
                        WarningTooltip2=""
                        @bind-Value="BotEquipmentLogging"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("BotEquipmentLogging"))"
                        IsNonDefault="@(!BotEquipmentLogging)"
                        OnUndo="UndoBotLog"
                        OnDefault="DefaultBotLog" />

                    <MudSwitchTTWarning
                        Label="Mod Import Tuning Logging"
                        TooltipText="Enable or disable mod import tuning for APBS. Tune your settings, save your config and read your server output."
                        WarningTooltip1="Remember to turn this back off when you're done tuning."
                        WarningTooltip2=""
                        @bind-Value="ModImportTuningLog"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModImportTuningLog"))"
                        IsNonDefault="@(ModImportTuningLog)"
                        OnUndo="UndoModImportTuningLog"
                        OnDefault="DefaultModImportTuningLog" />
                    
                    <MudSelectUndoDefaultTT
                        Label="Mod Import Tuning Bot Type"
                        TooltipText="Bot you want to test. Default means guards and followers."
                        Value="@ModImportTuningBot"
                        ValueChanged="@(x => ModImportTuningBot = x)"
                        Items="@_modImportTuningBots"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains(nameof(ModImportTuningBot)))"
                        IsNonDefault="@(ModImportTuningBot != "pmc")"
                        OnUndo="UndoModImportTuningBot"
                        OnDefault="DefaultModImportTuningBot" />
                    
                    <MudSliderDisabledTT
                        Label="Mod Import Tuning Tier"
                        TooltipText="Tier you want to test, this is the tier used for the output logging. Minimum value is the Initial Tier configured."
                        @bind-Value="ModImportTuningTier"
                        Min="ModInitialTierAppearance"
                        Max="7"
                        Disabled="@(!ModImportTuningLog)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModImportTuningTier"))"
                        IsNonDefault="@(ModImportTuningTier != 3)"
                        OnUndo="UndoModImportTuningTier"
                        OnDefault="DefaultModImportTuningTier" />

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Style="padding-bottom:25px" Text="Nothing to see here..." Expanded="false">
                <MudGrid>

                    <MudSwitchTT
                        Label="April Fool's Event"
