@page "/progressivebotsystem/modcompatibility"
@using ProgressiveBotSystem.Web.Components
@layout MainLayout

<MudMainContent>
    <MudContainer Class="mb-20">
        <MudExpansionPanels MultiExpansion="true">
            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Custom Item Importing" Expanded="true">
                <MudGrid>

                    <MudSwitchTT
                        Label="Modded Weapons"
                        TooltipText="Allows bots to use custom modded weapons."
                        @bind-Value="ModCustomWeaponsEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomWeaponsEnabled"))"
                        IsNonDefault="@(ModCustomWeaponsEnabled)"
                        OnUndo="UndoCustomWeapons"
                        OnDefault="DefaultCustomWeapons" />

                    <MudSwitchTTDisabledWarning
                        Label="Dynamic Weapon Weighting"
                        TooltipText="Automatically balances modded weapon weights against the vanilla pool. At 1.0 each modded weapon is equally likely as the average vanilla weapon, regardless of how many mods are installed."
                        WarningTooltip1="This is completely dynamic based on the existing mod pool, so test the values and see how you like it."
                        @bind-Value="UseDynamicWeaponWeights"
                        Disabled="@(!ModCustomWeaponsEnabled)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("UseDynamicWeaponWeights"))"
                        IsNonDefault="@(!UseDynamicWeaponWeights)"
                        OnUndo="UndoUseDynamicWeaponWeights"
                        OnDefault="DefaultUseDynamicWeaponWeights" />
                    
                    @if (UseDynamicWeaponWeights)
                    {
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Pmc Weapon Multiplier"
                            TooltipText="Controls how likely modded weapons are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicPmcWeaponWeightMultiplier"
                            Min="0.1"
                            Max="3.0"
                            Step="0.05"
                            Disabled="@(!UseDynamicWeaponWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicPmcWeaponWeightMultiplier"))"
                            IsNonDefault="@(Math.Abs(DynamicPmcWeaponWeightMultiplier - 1.0) > 0.001)"
                            OnUndo="UndoPmcDynamicWeaponWeightMultiplier"
                            OnDefault="DefaultPmcDynamicWeaponWeightMultiplier" />
                        
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Scav Weapon Multiplier"
                            TooltipText="Controls how likely modded weapons are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicScavWeaponWeightMultiplier"
                            Min="0.1"
                            Max="3.0"
                            Step="0.05"
                            Disabled="@(!UseDynamicWeaponWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicScavWeaponWeightMultiplier"))"
                            IsNonDefault="@(Math.Abs(DynamicScavWeaponWeightMultiplier - 1.0) > 0.001)"
                            OnUndo="UndoScavDynamicWeaponWeightMultiplier"
                            OnDefault="DefaultScavDynamicWeaponWeightMultiplier" />
                        
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Guard Weapon Multiplier"
                            TooltipText="Controls how likely modded weapons are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicGuardWeaponWeightMultiplier"
                            Min="0.1"
                            Max="3.0"
                            Step="0.05"
                            Disabled="@(!UseDynamicWeaponWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicGuardWeaponWeightMultiplier"))"
                            IsNonDefault="@(Math.Abs(DynamicGuardWeaponWeightMultiplier - 1.0) > 0.001)"
                            OnUndo="UndoGuardDynamicWeaponWeightMultiplier"
                            OnDefault="DefaultGuardDynamicWeaponWeightMultiplier" />
                    }
                    else
                    {
                        <MudSliderChildUndoDefaultTT
                            Label="Pmc Weapon Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom weapons, and see them often - try a lower number."
                            @bind-Value="ModPmcWeaponWeights"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomWeaponsEnabled || UseDynamicWeaponWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomWeaponsEnabled"))"
                            IsNonDefault="@(ModPmcWeaponWeights != 8)"
                            OnUndo="UndoPmcWeaponWeights"
                            OnDefault="DefaultPmcWeaponWeights" />

                        <MudSliderChildUndoDefaultTT
                            Label="Scav Weapon Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom weapons, and see them often - try a lower number."
                            @bind-Value="ModScavWeaponWeights"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomWeaponsEnabled || UseDynamicWeaponWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomWeaponsEnabled"))"
                            IsNonDefault="@(ModScavWeaponWeights != 1)"
                            OnUndo="UndoScavWeaponWeights"
                            OnDefault="DefaultScavWeaponWeights" />

                        <MudSliderChildUndoDefaultTT
                            Label="Guard Weapon Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom weapons, and see them often - try a lower number."
                            @bind-Value="ModFollowerWeaponWeights"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomWeaponsEnabled || UseDynamicWeaponWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModFollowerWeaponWeights"))"
                            IsNonDefault="@(ModFollowerWeaponWeights != 6)"
                            OnUndo="UndoFollowerWeaponWeights"
                            OnDefault="DefaultFollowerWeaponWeights" />
                    }

                    <MudSwitchTT
                        Label="Modded Equipment"
                        TooltipText="Allows bots to use custom modded equipment."
                        @bind-Value="ModCustomEquipmentEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomEquipmentEnabled"))"
                        IsNonDefault="@(ModCustomEquipmentEnabled)"
                        OnUndo="UndoCustomEquipment"
                        OnDefault="DefaultCustomEquipment" />
                    
                    <MudSwitchTTDisabledWarning
                        Label="Dynamic Equipment Weighting"
                        TooltipText="Automatically balances modded equipment weights against the vanilla pool per slot. At 1.0 each modded item is equally likely as the average vanilla item in that slot."
                        WarningTooltip1="This is completely dynamic based on the existing mod pool, so test the values and see how you like it."
                        @bind-Value="UseDynamicEquipmentWeights"
                        Disabled="@(!ModCustomEquipmentEnabled)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("UseDynamicEquipmentWeights"))"
                        IsNonDefault="@(!UseDynamicEquipmentWeights)"
                        OnUndo="UndoUseDynamicEquipmentWeights"
                        OnDefault="DefaultUseDynamicEquipmentWeights" />
                    
                    @if (UseDynamicEquipmentWeights)
                    {
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Headwear Multiplier"
                            TooltipText="Controls how likely modded headwear is relative to vanilla (no armour slots). 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynHeadwear"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynHeadwear"))"
                            IsNonDefault="@(Math.Abs(DynHeadwear - 1.0) > 0.001)"
                            OnUndo="UndoDynHeadwear"
                            OnDefault="DefaultDynHeadwear" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Headwear (With Slots) Multiplier"
                            TooltipText="Controls how likely modded headwear is relative to vanilla (armour slots). 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynHeadwearWithSlots"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynHeadwearWithSlots"))"
                            IsNonDefault="@(Math.Abs(DynHeadwearWithSlots - 1.0) > 0.001)"
                            OnUndo="UndoDynHeadwearWithSlots"
                            OnDefault="DefaultDynHeadwearWithSlots" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Armour Vest Multiplier"
                            TooltipText="Controls how likely modded armour vests are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicArmourVestValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicArmourVest"))"
                            IsNonDefault="@(Math.Abs(DynamicArmourVestValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicArmourVest"
                            OnDefault="DefaultDynamicArmourVest" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Armoured Rig Multiplier"
                            TooltipText="Controls how likely modded armoured rigs are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicArmouredRigValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicArmouredRigValue"))"
                            IsNonDefault="@(Math.Abs(DynamicArmouredRigValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicArmouredRig"
                            OnDefault="DefaultDynamicArmouredRig" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Tactical Vest Multiplier"
                            TooltipText="Controls how likely modded tactical vests are relative to vanilla (small grids). 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicTacticalVestValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicTacticalVestValue"))"
                            IsNonDefault="@(Math.Abs(DynamicTacticalVestValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicTacticalVest"
                            OnDefault="DefaultDynamicTacticalVest" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Tactical Vest (Large Grid) Multiplier"
                            TooltipText="Controls how likely modded tactical vests are relative to vanilla (large grids). 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicTacticalVestLargeGridValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicTacticalVestLargeGridValue"))"
                            IsNonDefault="@(Math.Abs(DynamicTacticalVestLargeGridValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicTacticalVestLargeGrid"
                            OnDefault="DefaultDynamicTacticalVestLargeGrid" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Backpack Multiplier"
                            TooltipText="Controls how likely modded backpacks are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicBackpackValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicBackpackValue"))"
                            IsNonDefault="@(Math.Abs(DynamicBackpackValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicBackpack"
                            OnDefault="DefaultDynamicBackpack" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Face Cover Multiplier"
                            TooltipText="Controls how likely modded unarmoured face covers are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicFaceCoverValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicFaceCoverValue"))"
                            IsNonDefault="@(Math.Abs(DynamicFaceCoverValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicFaceCover"
                            OnDefault="DefaultDynamicFaceCover" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Face Cover (AC 0-2) Multiplier"
                            TooltipText="Controls how likely modded face covers are relative to vanilla (class 0, 1, 2). 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicFaceCoverAc0Value"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicFaceCoverAc0Value"))"
                            IsNonDefault="@(Math.Abs(DynamicFaceCoverAc0Value - 1.0) > 0.001)"
                            OnUndo="UndoDynamicFaceCoverAc0"
                            OnDefault="DefaultDynamicFaceCoverAc0" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Face Cover (AC 3+) Multiplier"
                            TooltipText="Controls how likely modded face covers are relative to vanilla (class 3+). 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicFaceCoverAc3Value"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicFaceCoverAc3Value"))"
                            IsNonDefault="@(Math.Abs(DynamicFaceCoverAc3Value - 1.0) > 0.001)"
                            OnUndo="UndoDynamicFaceCoverAc3"
                            OnDefault="DefaultDynamicFaceCoverAc3" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Eyewear Multiplier"
                            TooltipText="Controls how likely modded eyewear are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicEyewearValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicEyewearValue"))"
                            IsNonDefault="@(Math.Abs(DynamicEyewearValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicEyewear"
                            OnDefault="DefaultDynamicEyewear" />
                
                        <MudSliderChildUndoDefaultTTDouble
                            Label="Earpiece Multiplier"
                            TooltipText="Controls how likely modded earpieces are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicEarpieceValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicEarpieceValue"))"
                            IsNonDefault="@(Math.Abs(DynamicEarpieceValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicEarpiece"
                            OnDefault="DefaultDynamicEarpiece" />

                        <MudSliderChildUndoDefaultTTDouble
                            Label="Armband Multiplier"
                            TooltipText="Controls how likely modded armbands are relative to vanilla. 1.0 = equal chance, 0.5 = half as likely, 2.0 = twice as likely."
                            @bind-Value="DynamicArmbandValue"
                            Min="0.1" 
                            Max="3.0" 
                            Step="0.05"
                            Disabled="@(!ModCustomEquipmentEnabled || !UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("DynamicArmbandValue"))"
                            IsNonDefault="@(Math.Abs(DynamicArmbandValue - 1.0) > 0.001)"
                            OnUndo="UndoDynamicArmband"
                            OnDefault="DefaultDynamicArmband" />
                    }
                    else
                    {
                        <MudSliderChildUndoDefaultTT
                            Label="Headwear Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. Probably not armoured."
                            @bind-Value="HeadwearWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("HeadwearWeight"))"
                            IsNonDefault="@(HeadwearWeight != 1)"
                            OnUndo="UndoHeadwearWeight"
                            OnDefault="DefaultHeadwearWeight" />
                        
                        <MudSliderChildUndoDefaultTT
                            Label="Headwear (With Slots) Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. With slots means they are probably armoured."
                            @bind-Value="HeadwearESlotWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("HeadwearESlotWeight"))"
                            IsNonDefault="@(HeadwearESlotWeight != 6)"
                            OnUndo="UndoHeadwearESlotWeight"
                            OnDefault="DefaultHeadwearESlotWeight" />
                        
                        <MudSliderChildUndoDefaultTT
                            Label="Armour Vest Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number."
                            @bind-Value="ArmourVestWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("ArmorVestWeight"))"
                            IsNonDefault="@(ArmourVestWeight != 10)"
                            OnUndo="UndoArmourVestWeight"
                            OnDefault="DefaultArmourVestWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Armoured Rig Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number."
                            @bind-Value="ArmouredRigWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("ArmouredRigWeight"))"
                            IsNonDefault="@(ArmouredRigWeight != 7)"
                            OnUndo="UndoArmouredRigWeight"
                            OnDefault="DefaultArmouredRigWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Tactical Vest Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. Smaller than 10 grid slots."
                            @bind-Value="TacticalVestWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("TacticalVestWeight"))"
                            IsNonDefault="@(TacticalVestWeight != 1)"
                            OnUndo="UndoTacticalVestWeight"
                            OnDefault="DefaultTacticalVestWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Tactical Vest (Large Grid) Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. Larger than 10 grid slots."
                            @bind-Value="TacticalVestGLengthWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("TacticalVestGLengthWeight"))"
                            IsNonDefault="@(TacticalVestGLengthWeight != 10)"
                            OnUndo="UndoTacticalVestGLengthWeight"
                            OnDefault="DefaultTacticalVestGLengthWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Backpack Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number."
                            @bind-Value="BackpackWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("BackpackWeight"))"
                            IsNonDefault="@(BackpackWeight != 5)"
                            OnUndo="UndoBackpackWeight"
                            OnDefault="DefaultBackpackWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Face Cover Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. Not armoured."
                            @bind-Value="FaceCoverWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("FaceCoverWeight"))"
                            IsNonDefault="@(FaceCoverWeight != 4)"
                            OnUndo="UndoFaceCoverWeight"
                            OnDefault="DefaultFaceCoverWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Face Cover (AC 0-2) Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. Armour Class 0-2."
                            @bind-Value="FaceCoverAc0Weight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("FaceCoverAc0Weight"))"
                            IsNonDefault="@(FaceCoverAc0Weight != 2)"
                            OnUndo="UndoFaceCoverAc0Weight"
                            OnDefault="DefaultFaceCoverAc0Weight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Face Cover (AC 3+) Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number. Armour Class 3+."
                            @bind-Value="FaceCoverAc3Weight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("FaceCoverAc3Weight"))"
                            IsNonDefault="@(FaceCoverAc3Weight != 1)"
                            OnUndo="UndoFaceCoverAc3Weight"
                            OnDefault="DefaultFaceCoverAc3Weight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Eyewear Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number."
                            @bind-Value="EyewearWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("EyewearWeight"))"
                            IsNonDefault="@(EyewearWeight != 1)"
                            OnUndo="UndoEyewearWeight"
                            OnDefault="DefaultEyewearWeight" />
            
                        <MudSliderChildUndoDefaultTT
                            Label="Earpiece Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number."
                            @bind-Value="EarpieceWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)"
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("EarpieceWeight"))"
                            IsNonDefault="@(EarpieceWeight != 5)"
                            OnUndo="UndoEarpieceWeight"
                            OnDefault="DefaultEarpieceWeight" />
                        
                        <MudSliderChildUndoDefaultTT
                            Label="Armband Weights"
                            TooltipText="Higher number is more common. If you import a lot of custom equipment, and see them often - try a lower number."
                            @bind-Value="ArmBandWeight"
                            Min="1"
                            Max="25"
                            Disabled="@(!ModCustomEquipmentEnabled || UseDynamicEquipmentWeights)" 
                            HasPendingChanges="@(MainLayout.pendingChanges.Contains("ArmBandWeight"))"
                            IsNonDefault="@(ArmBandWeight != 4)"
                            OnUndo="UndoArmBandWeight"
                            OnDefault="DefaultArmBandWeight" />
                    }

                    <MudSwitchTTDisabledWarning
                        Label="Modded Clothing"
                        TooltipText="Allows bots to use custom modded clothing."
                        WarningTooltip1="Automatically disabled if PMC Seasonal Appearance is enabled."
                        WarningTooltip2=""
                        @bind-Value="ModCustomClothingEnabled"
                        Disabled="@(EnableSeasonalPmcAppearance || UseDynamicEquipmentWeights)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomClothingEnabled"))"
                        IsNonDefault="@(ModCustomClothingEnabled)"
                        OnUndo="UndoCustomClothing"
                        OnDefault="DefaultCustomClothing" />

                    <MudSwitchTTWarning
                        Label="Modded Attachments"
                        TooltipText="Allows bots to use custom modded attachments."
                        WarningTooltip1="This puts mod attachments on vanilla weapons. Expect additional RAM usage on the server and longer import times."
                        WarningTooltip2=""
                        @bind-Value="ModCustomAttachmentsEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModCustomAttachmentsEnabled"))"
                        IsNonDefault="@(ModCustomAttachmentsEnabled)"
                        OnUndo="UndoCustomAttachments"
                        OnDefault="DefaultCustomAttachments" />

                    <MudSliderDisabledTT
                        Label="Tier Appearance Level"
                        TooltipText="Tier that custom weapons & equipment will start appearing on bots."
                        @bind-Value="ModInitialTierAppearance"
                        Min="1"
                        Max="7"
                        Disabled="@(!ModCustomWeaponsEnabled && !ModCustomEquipmentEnabled)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModInitialTierAppearance"))"
                        IsNonDefault="@(ModInitialTierAppearance != 3)"
                        OnUndo="UndoInitialTierAppearance"
                        OnDefault="DefaultInitialTierAppearance" />

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Compatibility Options" Expanded="true">
                <MudGrid>

                    <MudSwitchTT
                        Label="Vanilla Cursing Safeguard"
                        TooltipText="Prevents vanilla mods being added to vanilla attachments due to custom item filters."
                        @bind-Value="ModSafeGuardEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModSafeGuardEnabled"))"
                        IsNonDefault="@(!ModSafeGuardEnabled)"
                        OnUndo="UndoSafeGuard"
                        OnDefault="DefaultSafeGuard" />

                    <MudSwitchTTWarning
                        Label="MPR45 Canted Mount Safeguard"
                        TooltipText="Enabling this means if a modded item has a NcSTAR MPR45 in a slot, only allow the MPR45 to be in that slot."
                        WarningTooltip1="If you disable this, all Optical Devices will still be removed - but tactical devices will be allowed (they may block vision)."
                        WarningTooltip2=""
                        @bind-Value="ModMprSafeGuardEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModMprSafeGuardEnabled"))"
                        IsNonDefault="@(!ModMprSafeGuardEnabled)"
                        OnUndo="UndoMprSafeGuard"
                        OnDefault="DefaultMprSafeGuard" />

                    <MudSwitchTTWarning
                        Label="Unlootable Belts on PMCs"
                        TooltipText="Makes belts on PMCs in ArmBand slot unlootable, you can still view contents."
                        WarningTooltip1="Pack'N'Strap Only."
                        WarningTooltip2=""
                        @bind-Value="ModPackNStrapCompatibility"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModPackNStrapCompatibility"))"
                        IsNonDefault="@(!ModPackNStrapCompatibility)"
                        OnUndo="UndoPackNStrap"
                        OnDefault="DefaultPackNStrap" />

                    <MudSwitchTTWarning
                        Label="WTT Backport Dogtags"
                        TooltipText="Allows PMCs to spawn with WTT Backport Dogtags."
                        WarningTooltip1="WTT Backport Only."
                        WarningTooltip2=""
                        @bind-Value="ModWttBackportDogtags"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModWttBackportDogtags"))"
                        IsNonDefault="@(!ModWttBackportDogtags)"
                        OnUndo="UndoWttBackportDogtags"
                        OnDefault="DefaultWttBackportDogtags" />

                    <MudSwitchTTWarning
                        Label="WTT Armoury Bosses Have Variants"
                        TooltipText="Allows Bosses to also get the weapons that WTT intends for them. If disabled, they will only go to Pmcs, scavs, and guards."
                        WarningTooltip1="WTT Armoury Only."
                        WarningTooltip2=""
                        @bind-Value="ModWttArmouryBossVariantsOnBosses"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModWttArmouryBossVariantsOnBosses"))"
                        IsNonDefault="@(!ModWttArmouryBossVariantsOnBosses)"
                        OnUndo="UndoWttArmouryBosses"
                        OnDefault="DefaultArmouryBosses" />

                    <MudSwitchTTWarning
                        Label="WTT Armoury Others Have Variants"
                        TooltipText="Enabling this will also allow other bots to get those weapons. If disabled then they will only go to the bosses WTT has dictated."
                        WarningTooltip1="WTT Armoury Only."
                        WarningTooltip2=""
                        @bind-Value="ModWttArmouryBossVariantsOnOthers"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModWttArmouryBossVariantsOnOthers"))"
                        IsNonDefault="@(!ModWttArmouryBossVariantsOnOthers)"
                        OnUndo="UndoWttArmouryOthers"
                        OnDefault="DefaultWttArmouryOthers" />

                    <MudSwitchTTWarning
                        Label="Add Gas Masks to Bots"
                        TooltipText="Allows bots to use gas masks - if you don't use Hazard Zones then you don't need this."
                        WarningTooltip1="Realism Only."
                        WarningTooltip2=""
                        @bind-Value="ModRealismCompatibility"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("ModRealismCompatibility"))"
                        IsNonDefault="@(ModRealismCompatibility)"
                        OnUndo="UndoRealism"
                        OnDefault="DefaultRealism" />

                    <MudItem xs="1">
                        <MudPaper Class="d-flex justify-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Color="Color.Dark" Placement="Placement.Right" Arrow="true">
                                <ChildContent>
                                    <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                </ChildContent>
                                <TooltipContent>
                                    <MudText Typo="Typo.caption">If you have a mod that increases the max stack size of ammo, you may need to adjust this.</MudText><MudSpacer />
                                    <MudText Typo="Typo.caption">If the stack size of ammo is 10x higher than normal, then set this to 10% of normal.</MudText><MudSpacer />
                                    <MudText Typo="Typo.caption">Example: Mod changes ammo stacks to 600 - you need to set this to 2, so they get 2 stacks of 600 instead of 20 stacks of 600.</MudText><MudSpacer />
                                    <MudText Typo="Typo.caption">Do NOT mess with this unless you need it - it may cause bots to run out of ammo.</MudText>
                                </TooltipContent>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
