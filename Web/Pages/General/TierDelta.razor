                        @if (MainLayout.AppUndoButtonToggle && (
                        MainLayout.pendingChanges.Contains("_tierDeltaCustomTier1Min") ||
                        MainLayout.pendingChanges.Contains("_tierDeltaCustomTier1Max")))
