@page "/progressivebotsystem/botsettings"
@layout MainLayout

<MudMainContent>
    <MudContainer Class="mb-20">
        <MudExpansionPanels MultiExpansion="true">

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Normalization of AI" Expanded=true>
                <MudGrid>

                    <MudItem xs="1">
                        <MudPaper Class="d-flex justify-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="This applies to all bots, including bots disabled in APBS unless excluded." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Normalizes bot health. Applies to all bots unless excluded below." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Normalize Bot Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthEnable" Color="Color.Success" UncheckedColor="Color.Default" LabelPlacement="Placement.End">@AllNormalizeHealthEnable</MudSwitch>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_allNormalizeHealthEnable") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthEnable" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (AllNormalizeHealthEnable != false && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthEnable" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Head. Your head is attached to your chest. So it's your chest head." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Chest Head</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthHeadEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthHeadEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthHead</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthHead" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthHeadEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthHead") || MainLayout.pendingChanges.Contains("_allNormalizeHealthHeadEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthHead" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthHead != 35 || AllNormalizeHealthHeadEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthHead" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Chest. Toggle switch to enable or disable this body part." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Chest Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthChestEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthChestEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthChest</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthChest" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthChestEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthChest") || MainLayout.pendingChanges.Contains("_allNormalizeHealthChestEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthChest" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthChest != 85 || AllNormalizeHealthChestEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthChest" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Stomach. Toggle switch to enable or disable this body part." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Stomach Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthStomachEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthStomachEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthStomach</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthStomach" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthStomachEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthStomach") || MainLayout.pendingChanges.Contains("_allNormalizeHealthStomachEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthStomach" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthStomach != 70 || AllNormalizeHealthStomachEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthStomach" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Left Arm. Toggle switch to enable or disable this body part." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Left Arm Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthLeftArmEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthLeftArmEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthLeftArm</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthLeftArm" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthLeftArmEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthLeftArm") || MainLayout.pendingChanges.Contains("_allNormalizeHealthLeftArmEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthLeftArm" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthLeftArm != 60 || AllNormalizeHealthLeftArmEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthLeftArm" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Right Arm. Toggle switch to enable or disable this body part." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Right Arm Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthRightArmEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthRightArmEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthRightArm</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthRightArm" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthRightArmEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthRightArm") || MainLayout.pendingChanges.Contains("_allNormalizeHealthRightArmEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthRightArm" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthRightArm != 60 || AllNormalizeHealthRightArmEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthRightArm" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Left Leg. Toggle switch to enable or disable this body part." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Left Leg Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthLeftLegEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthLeftLegEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthLeftLeg</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthLeftLeg" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthLeftLegEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthLeftLeg") || MainLayout.pendingChanges.Contains("_allNormalizeHealthLeftLegEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthLeftLeg" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthLeftLeg != 65 || AllNormalizeHealthLeftLegEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthLeftLeg" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Health of Right Leg. Toggle switch to enable or disable this body part." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Right Leg Health</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeHealthRightLegEnable" Color="Color.Success" UncheckedColor="Color.Default" Disabled="!AllNormalizeHealthEnable"/>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="!AllNormalizeHealthRightLegEnable || !AllNormalizeHealthEnable">@AllNormalizeHealthRightLeg</MudButton>
                    </MudItem>
                    <MudItem xs="4">
                        <MudSlider @bind-Value="AllNormalizeHealthRightLeg" ValueLabel="true" Min="1" Max="250" Color="Color.Info" Size="Size.Medium" Disabled="!AllNormalizeHealthRightLegEnable || !AllNormalizeHealthEnable" />
                    </MudItem>
                    <MudItem xs="1">
                        @if ((MainLayout.pendingChanges.Contains("_allNormalizeHealthRightLeg") || MainLayout.pendingChanges.Contains("_allNormalizeHealthRightLegEnable")) && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthRightLeg" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small" >Undo</MudButton>
                        }
                        else if ((AllNormalizeHealthRightLeg != 65 || AllNormalizeHealthRightLegEnable != true) && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthRightLeg" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="2" />
                    <MudItem xs="9">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1"  Elevation="0">
                            <MudSelect T="string" Label="Excluded Bots"
                                       MultiSelection="true"
                                       SelectedValues="AllNormalizeHealthExcludedBots"
                                       SelectedValuesChanged="OnExcludedBotsValueChanged"
                                       Variant="Variant.Filled"
                                       AnchorOrigin="Origin.CenterLeft"
                                       Dense Clearable
                                       Disabled="!AllNormalizeHealthEnable">
                                @foreach (var name in _botNames)
                                {
                                    <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_allNormalizeHealthExcludedBots") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthExcludedBots" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (AllNormalizeHealthExcludedBots.Count > 0 && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthExcludedBots" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="1">
                        <MudPaper Class="d-flex justify-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="This applies to all bots, including bots disabled in APBS." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Normalizes bot skills. Applies to all non-PMC bots. Will set most skills to level 1. Primarily used to get rid of instant reload/silent footsteps." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Normalize Bot Skills</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="AllNormalizeSkillsEnable" Color="Color.Success" UncheckedColor="Color.Default" LabelPlacement="Placement.End">@AllNormalizeSkillsEnable</MudSwitch>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_allNormalizeSkillsEnable") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeSkillsEnable" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (AllNormalizeSkillsEnable != false && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeSkillsEnable" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                </MudGrid>
            </MudExpansionPanel>
            
            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Player Scav Settings" Expanded=true>
                <MudGrid>
                    
                    <MudItem xs="1">
                        <MudPaper Class="d-flex justify-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="These settings drastically change progression by altering your player scav." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Enabling allows you to adjust player scav configs." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Player Scav Options</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="PscavEnable" Color="Color.Success" UncheckedColor="Color.Default" LabelPlacement="Placement.End">@PscavEnable</MudSwitch>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_pscavEnable") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoPlayerScavEnable" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (PscavEnable != false && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultPlayerScavEnable" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>
                    
                    <MudItem xs="1"/>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Enabling will generate your scav with your Pmc skill values." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Use Pmc Skills</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="PscavEnablePmcSkills" Color="Color.Success" UncheckedColor="Color.Default" LabelPlacement="Placement.End" Disabled="!PscavEnable">@PscavEnablePmcSkills</MudSwitch>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_pscavEnablePmcSkills") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoPlayerScavPmcSkills" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (PscavEnablePmcSkills != false && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultPlayerScavPmcSkills" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>
                    
                    <MudItem xs="1"/>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Enabling will write back your skill gains during a Scav raid back to your Pmc." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Pmc Skill Writeback</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="PscavEnablePmcSkillWriteback" Color="Color.Success" UncheckedColor="Color.Default" LabelPlacement="Placement.End" Disabled="!PscavEnable">@PscavEnablePmcSkillWriteback</MudSwitch>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_pscavEnablePmcSkillWriteback") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoPlayerScavPmcSkillWriteback" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (PscavEnablePmcSkillWriteback != false && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultPlayerScavPmcSkillWriteback" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>
                    
                    <MudItem xs="1">
                        <MudPaper Class="d-flex justify-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Yes, this is super strong as you'll always have good ammo and gear." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudIconButton Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="4">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudTooltip Text="Enabling allows your player scav to regenerate as a boss based on configured chance, does not use boss skills." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                                <MudText>Scav as Boss</MudText>
                            </MudTooltip>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="6">
                        <MudPaper Class="d-flex align-center mud-width-full" Elevation="0">
                            <MudSwitch T="bool" @bind-Value="PscavEnableBossRegeneration" Color="Color.Success" UncheckedColor="Color.Default" LabelPlacement="Placement.End" Disabled="!PscavEnable">@PscavEnableBossRegeneration</MudSwitch>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("_pscavEnableBossRegeneration") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoPlayerScavBossEnable" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (PscavEnableBossRegeneration != false && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultPlayerScavBossEnable" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudItem xs="1" />
