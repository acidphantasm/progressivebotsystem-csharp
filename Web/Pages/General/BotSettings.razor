@page "/progressivebotsystem/botsettings"
@using _progressiveBotSystem.Web.Components
@layout MainLayout

<MudMainContent>
    <MudContainer Class="mb-20">
        <MudExpansionPanels MultiExpansion="true">

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Normalization of AI" Expanded="true">
                <MudGrid>

                    <MudSwitchTTWarning
                        Label="Normalize Bot Health"
                        TooltipText="Normalizes bot health. Applies to all bots unless excluded below."
                        WarningTooltip1="This applies to all bots, including bots disabled in APBS unless excluded."
                        WarningTooltip2=""
                        @bind-Value="AllNormalizeHealthEnable"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthEnable"))"
                        IsNonDefault="@(AllNormalizeHealthEnable)"
                        OnUndo="UndoNormalizeHealthEnable"
                        OnDefault="DefaultNormalizeHealthEnable" />

                    <MudSwitchSliderTT
                        Label="Chest Head"
                        TooltipText="Health of Head. Your head is attached to your chest. So it's your chest head."
                        @bind-ValueBool="AllNormalizeHealthHeadEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthHead"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthHeadEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthHeadEnable") || MainLayout.pendingChanges.Contains("AllNormalizeHealthHead"))"
                        IsNonDefault="@(AllNormalizeHealthHead != 35 || !AllNormalizeHealthHeadEnable)"
                        OnUndo="UndoNormalizeHealthHead"
                        OnDefault="DefaultNormalizeHealthHead" />

                    <MudSwitchSliderTT
                        Label="Chest Health"
                        TooltipText="Health of Chest. Toggle switch to enable or disable this body part."
                        @bind-ValueBool="AllNormalizeHealthChestEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthChest"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthChestEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthChestEnable") || MainLayout.pendingChanges.Contains("AllNormalizeHealthChest"))"
                        IsNonDefault="@(AllNormalizeHealthChest != 85 || !AllNormalizeHealthChestEnable)"
                        OnUndo="UndoNormalizeHealthChest"
                        OnDefault="DefaultNormalizeHealthChest" />

                    <MudSwitchSliderTT
                        Label="Stomach Health"
                        TooltipText="Health of Stomach. Toggle switch to enable or disable this body part."
                        @bind-ValueBool="AllNormalizeHealthStomachEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthStomach"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthStomachEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthStomach") || MainLayout.pendingChanges.Contains("AllNormalizeHealthStomachEnable"))"
                        IsNonDefault="@(AllNormalizeHealthStomach != 70 || AllNormalizeHealthStomachEnable != true)"
                        OnUndo="UndoNormalizeHealthStomach"
                        OnDefault="DefaultNormalizeHealthStomach" />
            
                    <MudSwitchSliderTT
                        Label="Left Arm Health"
                        TooltipText="Health of Left Arm. Toggle switch to enable or disable this body part."
                        @bind-ValueBool="AllNormalizeHealthLeftArmEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthLeftArm"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthLeftArmEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthLeftArm") || MainLayout.pendingChanges.Contains("AllNormalizeHealthLeftArmEnable"))"
                        IsNonDefault="@(AllNormalizeHealthLeftArm != 60 || !AllNormalizeHealthLeftArmEnable)"
                        OnUndo="UndoNormalizeHealthLeftArm"
                        OnDefault="DefaultNormalizeHealthLeftArm" />
            
                    <MudSwitchSliderTT
                        Label="Right Arm Health"
                        TooltipText="Health of Right Arm. Toggle switch to enable or disable this body part."
                        @bind-ValueBool="AllNormalizeHealthRightArmEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthRightArm"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthRightArmEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthRightArm") || MainLayout.pendingChanges.Contains("AllNormalizeHealthRightArmEnable"))"
                        IsNonDefault="@(AllNormalizeHealthRightArm != 60 || !AllNormalizeHealthRightArmEnable)"
                        OnUndo="UndoNormalizeHealthRightArm"
                        OnDefault="DefaultNormalizeHealthRightArm" />
            
                    <MudSwitchSliderTT
                        Label="Left Leg Health"
                        TooltipText="Health of Left Leg. Toggle switch to enable or disable this body part."
                        @bind-ValueBool="AllNormalizeHealthLeftLegEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthLeftLeg"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthLeftLegEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthLeftLeg") || MainLayout.pendingChanges.Contains("AllNormalizeHealthLeftLegEnable"))"
                        IsNonDefault="@(AllNormalizeHealthLeftLeg != 65 || !AllNormalizeHealthLeftLegEnable)"
                        OnUndo="UndoNormalizeHealthLeftLeg"
                        OnDefault="DefaultNormalizeHealthLeftLeg" />
            
                    <MudSwitchSliderTT
                        Label="Right Leg Health"
                        TooltipText="Health of Right Leg. Toggle switch to enable or disable this body part."
                        @bind-ValueBool="AllNormalizeHealthRightLegEnable"
                        DisabledSwitch="@(!AllNormalizeHealthEnable)"
                        @bind-ValueInt="AllNormalizeHealthRightLeg"
                        Min="1"
                        Max="250"
                        DisabledSlider="@(!AllNormalizeHealthRightLegEnable || !AllNormalizeHealthEnable)"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeHealthRightLeg") || MainLayout.pendingChanges.Contains("AllNormalizeHealthRightLegEnable"))"
                        IsNonDefault="@(AllNormalizeHealthRightLeg != 65 || !AllNormalizeHealthRightLegEnable)"
                        OnUndo="UndoNormalizeHealthRightLeg"
                        OnDefault="DefaultNormalizeHealthRightLeg" />

                    <MudItem xs="2" />
                    <MudItem xs="9">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudSelect T="string" Label="Excluded Bots"
                                       MultiSelection="true"
                                       SelectedValues="AllNormalizeHealthExcludedBots"
                                       SelectedValuesChanged="OnExcludedBotsValueChanged"
                                       Variant="Variant.Filled"
                                       AnchorOrigin="Origin.CenterLeft"
                                       Dense Clearable
                                       Disabled="!AllNormalizeHealthEnable">
                                @foreach (var name in _botNames)
                                {
                                    <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("AllNormalizeHealthExcludedBots") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoNormalizeHealthExcludedBots" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (AllNormalizeHealthExcludedBots.Count > 0 && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultNormalizeHealthExcludedBots" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                    <MudSwitchTTWarning
                        Label="Normalize Bot Skills"
                        TooltipText="Normalizes bot skills. Applies to all non-PMC bots. Will set most skills to level 1. Primarily used to get rid of instant reload/silent footsteps."
                        WarningTooltip1="This applies to all bots, including bots disabled in APBS."
                        WarningTooltip2=""
                        @bind-Value="AllNormalizeSkillsEnable"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllNormalizeSkillsEnable"))"
                        IsNonDefault="@(AllNormalizeSkillsEnable)"
                        OnUndo="UndoNormalizeSkillsEnable"
                        OnDefault="DefaultNormalizeSkillsEnable" />

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Player Scav Settings" Expanded="true">
                <MudGrid>

                    <MudSwitchTTWarning
                        Label="Player Scav Options"
                        TooltipText="Enabling allows you to adjust player scav configs."
                        WarningTooltip1="These settings drastically change progression by altering your player scav."
                        WarningTooltip2=""
                        @bind-Value="PscavEnable"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("PscavEnable"))"
                        IsNonDefault="@(PscavEnable)"
                        OnUndo="UndoPlayerScavEnable"
                        OnDefault="DefaultPlayerScavEnable" />

                    <MudSwitchTT
                        Label="Use Pmc Skills"
                        TooltipText="Enabling will generate your scav with your Pmc skill values."
                        @bind-Value="PscavEnablePmcSkills"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("PscavEnablePmcSkills"))"
                        IsNonDefault="@(PscavEnablePmcSkills)"
                        OnUndo="UndoPlayerScavPmcSkills"
                        OnDefault="DefaultPlayerScavPmcSkills" />

                    <MudSwitchTT
                        Label="Pmc Skill Writeback"
                        TooltipText="Enabling will write back your skill gains during a Scav raid back to your Pmc."
                        @bind-Value="PscavEnablePmcSkillWriteback"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("PscavEnablePmcSkillWriteback"))"
                        IsNonDefault="@(PscavEnablePmcSkillWriteback)"
                        OnUndo="UndoPlayerScavPmcSkillWriteback"
                        OnDefault="DefaultPlayerScavPmcSkillWriteback" />

                    <MudSwitchTTWarning
                        Label="Scav as Boss"
                        TooltipText="Enabling allows your player scav to regenerate as a boss based on configured chance, does not use boss skills."
                        WarningTooltip1="Yes, this is super strong as you'll always have good ammo and gear."
                        WarningTooltip2=""
                        @bind-Value="PscavEnableBossRegeneration"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("PscavEnableBossRegeneration"))"
                        IsNonDefault="@(PscavEnableBossRegeneration)"
                        OnUndo="UndoPlayerScavBossEnable"
                        OnDefault="DefaultPlayerScavBossEnable" />

                    <MudSliderChildTT
                        Label="Chance"
                        TooltipText="Chance of your player scav generating as a boss."
                        @bind-Value="PscavBossRegenerationChance"
                        Min="1"
                        Max="100"
                        Disabled="@(!PscavEnableBossRegeneration)" />

                    <MudSwitchTT
                        Label="Use Boss Health Values"
                        TooltipText="Enabling will use the bosses limb health values, if disabled will use your Pmcs limb health values."
                        @bind-Value="PscavEnableBossHealthValues"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("PscavEnableBossHealthValues"))"
                        IsNonDefault="@(PscavEnableBossHealthValues)"
                        OnUndo="UndoPlayerScavBossHealthValues"
                        OnDefault="DefaultPlayerScavBossHealthValues" />

                    <MudItem xs="2" />
                    <MudItem xs="9">
                        <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
                            <MudSelect T="string" Label="Allowed Bosses"
                                       MultiSelection="true"
                                       SelectedValues="PscavBossRegenerationAllowedBosses"
                                       SelectedValuesChanged="OnAllowedBossValueChanged"
                                       Variant="Variant.Filled"
                                       AnchorOrigin="Origin.CenterLeft"
                                       Dense Clearable
                                       Disabled="!PscavEnableBossRegeneration">
                                @foreach (var name in _bossNames)
                                {
                                    <MudSelectItem T="string" Value="@name">@name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="1">
                        @if (MainLayout.pendingChanges.Contains("PscavBossRegenerationAllowedBosses") && MainLayout.AppUndoButtonToggle)
                        {
                            <MudButton @onclick="UndoPlayerScavBossAllowedBosses" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
                        }
                        else if (PscavBossRegenerationAllowedBosses.Count > 0 && MainLayout.AppDefaultButtonToggle)
                        {
                            <MudButton @onclick="DefaultPlayerScavBossAllowedBosses" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
                        }
                    </MudItem>

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Map Weapon Selection Weighting" Expanded="true">
                <MudGrid>

                    <MapWeaponRangeWeighting
                        Label="Customs"
                        @bind-LongWeight="MapRangeWeightingCustomsLong"
                        @bind-ShortWeight="MapRangeWeightingCustomsShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingCustomsLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingCustomsShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingCustomsLong - 20) > 0.001 || Math.Abs(MapRangeWeightingCustomsShort - 80) > 0.001)"
                        OnUndo="UndoCustomsWeaponRangeWeights"
                        OnDefault="DefaultCustomsWeaponRangeWeights" />

                    <MapWeaponRangeWeighting
                        Label="Reserve"
                        @bind-LongWeight="MapRangeWeightingReserveLong"
                        @bind-ShortWeight="MapRangeWeightingReserveShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingReserveLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingReserveShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingReserveLong - 20) > 0.001 || Math.Abs(MapRangeWeightingReserveShort - 80) > 0.001)"
                        OnUndo="UndoReserveWeaponRangeWeights"
                        OnDefault="DefaultReserveWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Labs"
                        @bind-LongWeight="MapRangeWeightingLabsLong"
                        @bind-ShortWeight="MapRangeWeightingLabsShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingLabsLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingLabsShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingLabsLong - 10) > 0.001 || Math.Abs(MapRangeWeightingLabsShort - 90) > 0.001)"
                        OnUndo="UndoLabsWeaponRangeWeights"
                        OnDefault="DefaultLabsWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Factory Night"
                        @bind-LongWeight="MapRangeWeightingFactoryNightLong"
                        @bind-ShortWeight="MapRangeWeightingFactoryNightShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingFactoryNightLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingFactoryNightShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingFactoryNightLong - 5) > 0.001 || Math.Abs(MapRangeWeightingFactoryNightShort - 95) > 0.001)"
                        OnUndo="UndoFactoryNightWeaponRangeWeights"
                        OnDefault="DefaultFactoryNightWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Factory Day"
                        @bind-LongWeight="MapRangeWeightingFactoryDayLong"
                        @bind-ShortWeight="MapRangeWeightingFactoryDayShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingFactoryDayLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingFactoryDayShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingFactoryDayLong - 5) > 0.001 || Math.Abs(MapRangeWeightingFactoryDayShort - 95) > 0.001)"
                        OnUndo="UndoFactoryDayWeaponRangeWeights"
                        OnDefault="DefaultFactoryDayWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Interchange"
                        @bind-LongWeight="MapRangeWeightingInterchangeLong"
                        @bind-ShortWeight="MapRangeWeightingInterchangeShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingInterchangeLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingInterchangeShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingInterchangeLong - 20) > 0.001 || Math.Abs(MapRangeWeightingInterchangeShort - 80) > 0.001)"
                        OnUndo="UndoInterchangeWeaponRangeWeights"
                        OnDefault="DefaultInterchangeWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Ground Zero"
                        @bind-LongWeight="MapRangeWeightingSandboxLong"
                        @bind-ShortWeight="MapRangeWeightingSandboxShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingSandboxLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingSandboxShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingSandboxLong - 15) > 0.001 || Math.Abs(MapRangeWeightingSandboxShort - 85) > 0.001)"
                        OnUndo="UndoSandboxWeaponRangeWeights"
                        OnDefault="DefaultSandboxWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Ground Zero (21+)"
                        @bind-LongWeight="MapRangeWeightingSandboxHighLong"
                        @bind-ShortWeight="MapRangeWeightingSandboxHighShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingSandboxHighLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingSandboxHighShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingSandboxHighLong - 15) > 0.001 || Math.Abs(MapRangeWeightingSandboxHighShort - 85) > 0.001)"
                        OnUndo="UndoSandboxHighWeaponRangeWeights"
                        OnDefault="DefaultSandboxHighWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Woods"
                        @bind-LongWeight="MapRangeWeightingWoodsLong"
                        @bind-ShortWeight="MapRangeWeightingWoodsShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingWoodsLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingWoodsShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingWoodsLong - 60) > 0.001 || Math.Abs(MapRangeWeightingWoodsShort - 40) > 0.001)"
                        OnUndo="UndoWoodsWeaponRangeWeights"
                        OnDefault="DefaultWoodsWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Shoreline"
                        @bind-LongWeight="MapRangeWeightingShorelineLong"
                        @bind-ShortWeight="MapRangeWeightingShorelineShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingShorelineLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingShorelineShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingShorelineLong - 50) > 0.001 || Math.Abs(MapRangeWeightingShorelineShort - 50) > 0.001)"
                        OnUndo="UndoShorelineWeaponRangeWeights"
                        OnDefault="DefaultShorelineWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Lighthouse"
                        @bind-LongWeight="MapRangeWeightingLighthouseLong"
                        @bind-ShortWeight="MapRangeWeightingLighthouseShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingLighthouseLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingLighthouseShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingLighthouseLong - 30) > 0.001 || Math.Abs(MapRangeWeightingLighthouseShort - 70) > 0.001)"
                        OnUndo="UndoLighthouseWeaponRangeWeights"
                        OnDefault="DefaultLighthouseWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="TarkovStreets"
                        @bind-LongWeight="MapRangeWeightingTarkovStreetsLong"
                        @bind-ShortWeight="MapRangeWeightingTarkovStreetsShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingTarkovStreetsLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingTarkovStreetsShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingTarkovStreetsLong - 20) > 0.001 || Math.Abs(MapRangeWeightingTarkovStreetsShort - 80) > 0.001)"
                        OnUndo="UndoTarkovStreetsWeaponRangeWeights"
                        OnDefault="DefaultTarkovStreetsWeaponRangeWeights" />
            
                    <MapWeaponRangeWeighting
                        Label="Labyrinth"
                        @bind-LongWeight="MapRangeWeightingLabyrinthLong"
                        @bind-ShortWeight="MapRangeWeightingLabyrinthShort"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("MapRangeWeightingLabyrinthLong") || MainLayout.pendingChanges.Contains("MapRangeWeightingLabyrinthShort"))"
                        IsNonDefault="@(Math.Abs(MapRangeWeightingLabyrinthLong - 5) > 0.001 || Math.Abs(MapRangeWeightingLabyrinthShort - 95) > 0.001)"
                        OnUndo="UndoLabyrinthWeaponRangeWeights"
                        OnDefault="DefaultLabyrinthWeaponRangeWeights" />

                </MudGrid>
            </MudExpansionPanel>

            <MudExpansionPanel Class="mud-expansion-panels-borders ma-3 pa-5" Text="Weapon & Armour Configurations" Expanded="true">
                <MudGrid>

                    <MudSwitchTT
                        Label="Per Weapon Category Attachment Chances"
                        TooltipText="Allows bots to use different chances for each slot, depending on the category of weapon they have selected."
                        @bind-Value="AllPerWeaponAttachmentRolls"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllPerWeaponAttachmentRolls"))"
                        IsNonDefault="@(!AllPerWeaponAttachmentRolls)"
                        OnUndo="UndoPerWeaponAttachmentRolls"
                        OnDefault="DefaultPerWeaponAttachmentRolls" />

                    <MudSwitchTT
                        Label="Large Capacity Magazine Limit"
                        TooltipText="Limits the amount of large capacity (36 rounds or higher) magazines a bot can spawn with (per weapon)."
                        @bind-Value="AllWeaponLargeCapacityMagazineLimitEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponLargeCapacityMagazineLimitEnabled") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponLargeCapacityMagazineCount"))"
                        IsNonDefault="@(!AllWeaponLargeCapacityMagazineLimitEnabled || AllWeaponLargeCapacityMagazineCount != 2)"
                        OnUndo="UndoLargeCapacityMagazineLimit"
                        OnDefault="DefaultLargeCapacityMagazineLimit" />

                    <MudSliderChildTT
                        Label="Large Capacity Magazines Count"
                        TooltipText="This is the count for the limit on the number of large capacity magazines a bot can have, individually, for each weapon."
                        @bind-Value="AllWeaponLargeCapacityMagazineCount"
                        Min="1"
                        Max="4"
                        Disabled="@(!AllWeaponLargeCapacityMagazineLimitEnabled)" />

                    <MudSliderTT
                        Label="Buttpad Chance"
                        TooltipText="This is the chance that bot weapons, that have a stock with an available buttpad have one."
                        @bind-Value="AllWeaponButtpadChance"
                        Min="1"
                        Max="100" 
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponButtpadChance"))"
                        IsNonDefault="@(AllWeaponButtpadChance != 50)"
                        OnUndo="UndoWeaponButtpadChance"
                        OnDefault="DefaultWeaponButtpadChance" />

                    <MudSwitchTT
                        Label="Force Stock"
                        TooltipText="Forces bots to use a stock if their weapon allows it."
                        @bind-Value="AllWeaponForceStock"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponForceStock"))"
                        IsNonDefault="@(AllWeaponForceStock)"
                        OnUndo="UndoWeaponForceStock"
                        OnDefault="DefaultWeaponForceStock" />

                    <MudSwitchTT
                        Label="Force Dust Cover"
                        TooltipText="Forces bots to use a dust cover if their weapon allows it."
                        @bind-Value="AllWeaponForceDustcover"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponForceDustcover"))"
                        IsNonDefault="@(AllWeaponForceDustcover)"
                        OnUndo="UndoWeaponForceDustcover"
                        OnDefault="DefaultWeaponForceDustcover" />

                    <MudSwitchTTWarning
                        Label="Force Optical Devices"
                        TooltipText="Forces bots to use an optic if their weapon allows it."
                        WarningTooltip1="Due to BSG - this may also caused unwanted tactical attachments."
                        WarningTooltip2=""
                        @bind-Value="AllWeaponForceOpticalDevice"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponForceOpticalDevice"))"
                        IsNonDefault="@(AllWeaponForceOpticalDevice)"
                        OnUndo="UndoWeaponForceOpticalDevice"
                        OnDefault="DefaultWeaponForceOpticalDevice" />

                    <MudSwitchTT
                        Label="Force Muzzle Children Attachments"
                        TooltipText="If a muzzle is selected for their weapon, this will force it to have it's children attachments (muzzle device -> suppressor)."
                        @bind-Value="AllWeaponForceMuzzleChildren"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponForceMuzzleChildren"))"
                        IsNonDefault="@(AllWeaponForceMuzzleChildren)"
                        OnUndo="UndoWeaponForceMuzzleChildren"
                        OnDefault="DefaultWeaponForceMuzzleChildren" />

                    <MudSwitchTT
                        Label="Override Muzzle Chances"
                        TooltipText="Override default database and preset chances of having a muzzle, if their weapon allows it."
                        @bind-Value="AllWeaponOverrideMuzzleChanceEnabled"
                        HasPendingChanges="@(MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceEnabled") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier1") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier2") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier3") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier4") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier5") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier6") ||
                                            MainLayout.pendingChanges.Contains("AllWeaponOverrideMuzzleChanceValueTier7"))"
                        IsNonDefault="@(AllWeaponOverrideMuzzleChanceEnabled ||
                                        !AllWeaponOverrideMuzzleChanceValues.SequenceEqual(ModConfig.OriginalConfig.GeneralConfig.MuzzleChance))"
                        OnUndo="UndoWeaponOverrideMuzzleChances"
                        OnDefault="DefaultWeaponOverrideMuzzleChances" />

                    <MudItem xs="2" />
                    <MudItem xs="3">
                        <MudTooltip Text="Chance of weapon having a muzzle device, configurable per tier, if their weapon allows it." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
                            <MudText>Muzzle Chance</MudText>
                        </MudTooltip>
                    </MudItem>
                    <MudItem xs="7">
                        <MudPaper Class="d-flex align-start mud-width-full" Style="margin-top: -20px;" Elevation="0">
                            <MudNumericField Margin="Margin.Dense" HideSpinButtons @bind-Value="AllWeaponOverrideMuzzleChanceValueTier1" Label="Weight" HelperText="Tier 1" Variant="Variant.Filled" Min="1" Max="100" Disabled="!AllWeaponOverrideMuzzleChanceEnabled" />
                            <MudNumericField Margin="Margin.Dense" HideSpinButtons @bind-Value="AllWeaponOverrideMuzzleChanceValueTier2" Label="Weight" HelperText="Tier 2" Variant="Variant.Filled" Min="1" Max="100" Disabled="!AllWeaponOverrideMuzzleChanceEnabled" />
                            <MudNumericField Margin="Margin.Dense" HideSpinButtons @bind-Value="AllWeaponOverrideMuzzleChanceValueTier3" Label="Weight" HelperText="Tier 3" Variant="Variant.Filled" Min="1" Max="100" Disabled="!AllWeaponOverrideMuzzleChanceEnabled" />
