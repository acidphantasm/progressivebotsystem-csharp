<MudItem xs="2" />
<MudItem xs="3">
    <MudTooltip Text="@($"Adjust {Label} durability values.")" Color="Color.Primary" Placement="Placement.Right" Arrow="true">
        <MudText>@($"{Label} Durability Values")</MudText>
    </MudTooltip>
</MudItem>
<MudItem xs="2">
    <MudPaper Class="d-flex align-start mud-width-full" Style="margin-top: -20px;" Elevation="0">
        <MudTooltip Text="@($"Lowest a {Label}'s 'non-repairable' durability can be.")" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField Margin="Margin.Dense" HideSpinButtons="true" Value="@Min"
                             ValueChanged="@(EventCallback.Factory.Create<int>(this, OnMinChanged))"
                             Label="Min" HelperText="Durability" Variant="Variant.Filled"
                             Min="0" Max="@(Max - MinDelta + MaxDelta - 1)" Disabled="@Disabled" />
        </MudTooltip>
        <MudTooltip Text="@($"Highest a {Label}'s 'non-repairable' durability can be.")" Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField Margin="Margin.Dense" HideSpinButtons="true" Value="@Max"
                             ValueChanged="@(EventCallback.Factory.Create<int>(this, OnMaxChanged))"
                             Label="Max" HelperText="Durability" Variant="Variant.Filled"
                             Min="@(Min - MaxDelta + MinDelta + 1)" Max="100" Disabled="@Disabled" />
        </MudTooltip>
    </MudPaper>
</MudItem>
<MudItem xs="2">
    <MudPaper Class="d-flex align-start mud-width-full" Style="margin-top: -20px;" Elevation="0">
        <MudTooltip Text="Lowest possible difference from the rolled 'non-repairable' durability to the 'current' durability." Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField Margin="Margin.Dense" HideSpinButtons="true" Value="@MinDelta"
                             ValueChanged="@(EventCallback.Factory.Create<int>(this, OnMinDeltaChanged))"
                             Label="Min" HelperText="Delta" Variant="Variant.Filled"
                             Min="0" Max="@(Max - Min + MaxDelta - 1)" Disabled="@Disabled" />
        </MudTooltip>
        <MudTooltip Text="Highest possible difference from the rolled 'non-repairable' durability to the 'current' durability." Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField Margin="Margin.Dense" HideSpinButtons="true" Value="@MaxDelta"
                             ValueChanged="@(EventCallback.Factory.Create<int>(this, OnMaxDeltaChanged))"
                             Label="Max" HelperText="Delta" Variant="Variant.Filled"
                             Min="@(Math.Max(0, Min - Max + MinDelta + 1))" Max="@Min" Disabled="@Disabled" />
        </MudTooltip>
    </MudPaper>
</MudItem>
<MudItem xs="2">
    <MudPaper Class="d-flex align-start mud-width-full" Style="margin-top: -20px;" Elevation="0">
        <MudTooltip Text="Lowest Possible Current Durability Roll." Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField Disabled Margin="Margin.Dense" HideSpinButtons="true" Value="@MinLimitPercent"
                Label="Min" HelperText="Actual" Variant="Variant.Filled" Min="0" Max="100" />
        </MudTooltip>
        <MudTooltip Text="Highest Possible Current Durability Roll." Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField Disabled Margin="Margin.Dense" HideSpinButtons="true" Value="@MaxLimitPercent"
                Label="Max" HelperText="Actual" Variant="Variant.Filled" Min="0" Max="100" />
        </MudTooltip>
    </MudPaper>
</MudItem>
<MudItem xs="1" />

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public int Min { get; set; }
    [Parameter] public EventCallback<int> MinChanged { get; set; }
    [Parameter] public int Max { get; set; }
    [Parameter] public EventCallback<int> MaxChanged { get; set; }
    [Parameter] public int MinDelta { get; set; }
    [Parameter] public EventCallback<int> MinDeltaChanged { get; set; }
    [Parameter] public int MaxDelta { get; set; }
    [Parameter] public EventCallback<int> MaxDeltaChanged { get; set; }
    [Parameter] public int MinLimitPercent { get; set; }
    [Parameter] public int MaxLimitPercent { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private async Task OnMinChanged(int value)
    {
        var maxAllowed = Max - MinDelta + MaxDelta - 1;
        value = Math.Min(value, maxAllowed);
        await MinChanged.InvokeAsync(value);
    }

    private async Task OnMaxChanged(int value)
    {
        var minAllowed = Min - MaxDelta + MinDelta + 1;
        value = Math.Max(value, minAllowed);
        await MaxChanged.InvokeAsync(value);
    }

    private async Task OnMinDeltaChanged(int value)
    {
        var maxAllowed = Max - Min + MaxDelta - 1;
        value = Math.Min(value, maxAllowed);
        await MinDeltaChanged.InvokeAsync(value);
    }

    private async Task OnMaxDeltaChanged(int value)
    {
        var floor = Min - Max + MinDelta + 1;
        var ceiling = Min;
        value = Math.Clamp(value, Math.Max(0, floor), ceiling);
        await MaxDeltaChanged.InvokeAsync(value);
    }
}