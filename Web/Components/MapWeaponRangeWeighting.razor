<MudItem xs="1" />
<MudItem xs="4" Style="margin-top: 20px;">
    <MudTooltip Text="Adjust weapon range selection weights. Higher is more common." Color="Color.Primary" Placement="Placement.Right" Arrow="true">
        <MudText>@Label</MudText>
    </MudTooltip>
</MudItem>
<MudItem xs="6">
    <MudPaper Class="d-flex align-start mud-width-full" Elevation="0">
        <MudTooltip Text="Long range weapon selection weight." Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField T="double" Margin="Margin.Dense" HideSpinButtons="true"
                             Value="LongWeight"
                             ValueChanged="@(v => { LongWeightChanged.InvokeAsync(v); StateHasChanged(); })"
                             Label="Weight" HelperText="Long Range" Variant="Variant.Filled" Min="0" Max="100" />
        </MudTooltip>
        <MudTooltip Text="Short range weapon selection weight." Color="Color.Primary" Placement="Placement.Bottom" Arrow="true">
            <MudNumericField T="double" Margin="Margin.Dense" HideSpinButtons="true"
                             Value="ShortWeight"
                             ValueChanged="@(v => { ShortWeightChanged.InvokeAsync(v); StateHasChanged(); })"
                             Label="Weight" HelperText="Short Range" Variant="Variant.Filled" Min="0" Max="100" />
        </MudTooltip>
    </MudPaper>
</MudItem>
<MudItem xs="1">
    @if (HasPendingChanges && MainLayout.AppUndoButtonToggle)
    {
        <MudButton @onclick="OnUndo" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
    }
    else if (IsNonDefault && MainLayout.AppDefaultButtonToggle)
    {
        <MudButton @onclick="OnDefault" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
    }
</MudItem>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public double LongWeight { get; set; }
    [Parameter] public EventCallback<double> LongWeightChanged { get; set; }
    [Parameter] public double ShortWeight { get; set; }
    [Parameter] public EventCallback<double> ShortWeightChanged { get; set; }
    [Parameter] public bool HasPendingChanges { get; set; }
    [Parameter] public bool IsNonDefault { get; set; }
    [Parameter] public EventCallback OnUndo { get; set; }
    [Parameter] public EventCallback OnDefault { get; set; }
}