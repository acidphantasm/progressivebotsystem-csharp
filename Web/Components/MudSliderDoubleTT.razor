<MudItem xs="2" />
<MudItem xs="3">
    <MudPaper Class="d-flex align-center mud-width-full ma-1" Elevation="0">
        <MudTooltip Text="@TooltipText" Color="Color.Primary" Placement="Placement.Right" Arrow="true">
            <MudText>@Label</MudText>
        </MudTooltip>
    </MudPaper>
</MudItem>
<MudItem xs="1">
    <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small" Disabled="@Disabled">@Value</MudButton>
</MudItem>
<MudItem xs="5">
    <MudSlider Value="@Value" ValueChanged="@ValueChanged" ValueLabel="true" Min="@Min" Max="@Max" Step="0.01" Color="Color.Info" Size="Size.Medium" Disabled="@Disabled" />
</MudItem>
<MudItem xs="1">
    @if (HasPendingChanges && MainLayout.AppUndoButtonToggle)
    {
        <MudButton @onclick="OnUndo" Variant="Variant.Filled" Color="Color.Inherit" Size="Size.Small">Undo</MudButton>
    }
    else if (IsNonDefault && MainLayout.AppDefaultButtonToggle)
    {
        <MudButton @onclick="OnDefault" Variant="Variant.Filled" Color="Color.Dark" Size="Size.Small">Default</MudButton>
    }
</MudItem>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string TooltipText { get; set; } = "";
    [Parameter] public double Value { get; set; }
    [Parameter] public EventCallback<double> ValueChanged { get; set; }
    [Parameter] public bool HasPendingChanges { get; set; }
    [Parameter] public bool IsNonDefault { get; set; }
    [Parameter] public EventCallback OnUndo { get; set; }
    [Parameter] public EventCallback OnDefault { get; set; }
    [Parameter] public double Min { get; set; } = 0.01;
    [Parameter] public double Max { get; set; } = 0.5;
    [Parameter] public bool Disabled { get; set; } = false;
}